    {
      "cell_type": "code",
      "source": [
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CORRECTION TESTS MULTIPLES — Réponse critique reviewer               ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from scipy.stats import mannwhitneyu, spearmanr, chi2_contingency\n",
        "from statsmodels.stats.multitest import multipletests\n",
        "from itertools import combinations\n",
        "\n",
        "print(\"=\" * 65)\n",
        "print(\"CORRECTION POUR TESTS MULTIPLES — STRATÉGIE PAR FAMILLE\")\n",
        "print(\"=\" * 65)\n",
        "\n",
        "print(\"\"\"\n",
        "PRINCIPE :\n",
        "  - Test omnibus (Kruskal-Wallis) : 1 seule hypothèse → PAS de correction\n",
        "  - Comparaisons post-hoc par paires : Bonferroni (famille F1)\n",
        "  - V de Cramér (exploration) : FDR Benjamini-Hochberg (famille F2)\n",
        "  - Corrélations de Spearman : FDR Benjamini-Hochberg (famille F3)\n",
        "  - Régressions ordinales : aucune (inférence par modèle global)\n",
        "\"\"\")\n",
        "\n",
        "# ── FAMILLE F1 — Post-hoc par paires (k=4 clusters) ─────────────────────\n",
        "print(\"─\" * 65)\n",
        "print(\"FAMILLE F1 — Comparaisons post-hoc par paires\")\n",
        "print(\"(Bonferroni, 6 paires pour k=4)\")\n",
        "print(\"─\" * 65)\n",
        "\n",
        "CHOSEN_K = 4\n",
        "pairs    = list(combinations(range(CHOSEN_K), 2))\n",
        "n_pairs  = len(pairs)  # = 6\n",
        "\n",
        "posthoc_vars = {\n",
        "    \"Score confort\"    : \"score_confort\",\n",
        "    \"Satisfaction été\" : \"sat_ete_num\",\n",
        "    \"Satisfaction hiver\": \"sat_hiver_num\",\n",
        "}\n",
        "\n",
        "for var_lbl, var_col in posthoc_vars.items():\n",
        "    print(f\"\\n  {var_lbl} (Bonferroni, α/6 = {0.05/n_pairs:.4f}) :\")\n",
        "    print(f\"  {'Paire':<12} {'U':>8} {'p brut':>10} {'p Bonf.':>10} {'Sig':>6} {'Note':>15}\")\n",
        "    print(\"  \" + \"─\"*62)\n",
        "\n",
        "    p_bruts = []\n",
        "    U_vals  = []\n",
        "    for p0, p1 in pairs:\n",
        "        g0 = df_cl[df_cl[\"cluster\"]==p0][var_col].dropna()\n",
        "        g1 = df_cl[df_cl[\"cluster\"]==p1][var_col].dropna()\n",
        "        U, p = mannwhitneyu(g0, g1, alternative=\"two-sided\")\n",
        "        p_bruts.append(p); U_vals.append(U)\n",
        "\n",
        "    p_corr = [min(p * n_pairs, 1.0) for p in p_bruts]  # Bonferroni\n",
        "    # Alternative : multipletests pour vérification\n",
        "    reject, p_corr_mt, _, _ = multipletests(p_bruts, method=\"bonferroni\")\n",
        "\n",
        "    for i, (p0, p1) in enumerate(pairs):\n",
        "        sig_b = \"***\" if p_corr[i]<0.001 else (\"**\" if p_corr[i]<0.01 else\n",
        "                (\"*\" if p_corr[i]<0.05 else \"ns\"))\n",
        "        sig_r = \"***\" if p_bruts[i]<0.001 else (\"**\" if p_bruts[i]<0.01 else\n",
        "                (\"*\" if p_bruts[i]<0.05 else \"ns\"))\n",
        "        note  = \"Sig. perdu\" if sig_r != \"ns\" and sig_b == \"ns\" else \"\"\n",
        "        print(f\"  C{p0} vs C{p1}     {U_vals[i]:>8.0f} {p_bruts[i]:>10.4f} \"\n",
        "              f\"{p_corr[i]:>10.4f} {sig_b:>6} {note:>15}\")\n",
        "\n",
        "# ── FAMILLE F2 — V de Cramér ──────────────────────────────────────────────\n",
        "print(f\"\\n{'─'*65}\")\n",
        "print(\"FAMILLE F2 — V de Cramér (7 variables × 4 cibles = 28 tests)\")\n",
        "print(\"(FDR Benjamini-Hochberg, moins conservateur que Bonferroni)\")\n",
        "print(\"─\" * 65)\n",
        "\n",
        "arch_vars = {\n",
        "    \"Type de vitrage\"  : \"vitrage_type\",\n",
        "    \"État volets\"      : \"volet_etat\",\n",
        "    \"État toiture\"     : \"toiture_etat\",\n",
        "    \"Infiltration air\" : \"infiltr_air\",\n",
        "    \"Infiltration eau\" : \"infiltr_eau\",\n",
        "    \"Humidité\"         : \"humidite\",\n",
        "    \"Courants froids\"  : \"courants_froids\",\n",
        "}\n",
        "target_vars = {\n",
        "    \"Sensation\"        : \"sensation\",\n",
        "    \"Satisfaction été\" : \"sat_ete\",\n",
        "    \"Sat. hiver\"       : \"sat_hiver\",\n",
        "    \"Cluster CAH\"      : \"cluster_label\",\n",
        "}\n",
        "\n",
        "def cramers_v(x, y):\n",
        "    ct = pd.crosstab(x, y)\n",
        "    chi2, p, dof, _ = chi2_contingency(ct)\n",
        "    n = ct.sum().sum()\n",
        "    r, k = ct.shape\n",
        "    return np.sqrt(chi2 / (n*(min(r,k)-1))), p\n",
        "\n",
        "# Collecter tous les p-values\n",
        "rows_f2 = []\n",
        "for arch_lbl, arch_col in arch_vars.items():\n",
        "    for tgt_lbl, tgt_col in target_vars.items():\n",
        "        tmp = df_cl[[arch_col, tgt_col]].dropna()\n",
        "        if len(tmp) > 10:\n",
        "            v, p = cramers_v(tmp[arch_col], tmp[tgt_col])\n",
        "            rows_f2.append({\n",
        "                \"Variable archi\": arch_lbl,\n",
        "                \"Cible\"         : tgt_lbl,\n",
        "                \"V\"             : round(v, 3),\n",
        "                \"p_brut\"        : round(p, 4),\n",
        "            })\n",
        "\n",
        "f2_df = pd.DataFrame(rows_f2)\n",
        "\n",
        "# Correction FDR BH\n",
        "reject, p_fdr, _, _ = multipletests(f2_df[\"p_brut\"].values, method=\"fdr_bh\")\n",
        "f2_df[\"p_FDR\"]    = p_fdr.round(4)\n",
        "f2_df[\"sig_brut\"] = f2_df[\"p_brut\"].apply(\n",
        "    lambda p: \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"ns\")))\n",
        "f2_df[\"sig_FDR\"]  = f2_df[\"p_FDR\"].apply(\n",
        "    lambda p: \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"ns\")))\n",
        "f2_df[\"Cohen\"]    = f2_df[\"V\"].apply(\n",
        "    lambda v: \"nég.\" if v<0.10 else (\"petit\" if v<0.30 else (\"moyen\" if v<0.50 else \"grand\")))\n",
        "\n",
        "print(f\"\\n{'Variable archi':<22} {'Cible':<18} {'V':>5} {'p_brut':>8} \"\n",
        "      f\"{'p_FDR':>8} {'Sig_brut':>9} {'Sig_FDR':>8} {'Cohen':>7}\")\n",
        "print(\"─\"*90)\n",
        "for _, row in f2_df.iterrows():\n",
        "    changed = \" ←\" if row[\"sig_brut\"] != row[\"sig_FDR\"] else \"\"\n",
        "    print(f\"{row['Variable archi']:<22} {row['Cible']:<18} {row['V']:>5.3f} \"\n",
        "          f\"{row['p_brut']:>8.4f} {row['p_FDR']:>8.4f} \"\n",
        "          f\"{row['sig_brut']:>9} {row['sig_FDR']:>8} {row['Cohen']:>7}{changed}\")\n",
        "\n",
        "n_changed = (f2_df[\"sig_brut\"] != f2_df[\"sig_FDR\"]).sum()\n",
        "print(f\"\\n→ {n_changed} associations changent de significativité après correction FDR\")\n",
        "print(\"  ← marque les tests dont la significativité change\")\n",
        "\n",
        "# ── FAMILLE F3 — Corrélations de Spearman ────────────────────────────────\n",
        "print(f\"\\n{'─'*65}\")\n",
        "print(\"FAMILLE F3 — Corrélations de Spearman avec score_confort\")\n",
        "print(\"(FDR Benjamini-Hochberg)\")\n",
        "print(\"─\" * 65)\n",
        "\n",
        "corr_vars = {\n",
        "    \"Satisfaction été\"   : \"sat_ete_num\",\n",
        "    \"Satisfaction hiver\" : \"sat_hiver_num\",\n",
        "    \"Sensation\"          : \"sensation_num\",\n",
        "    \"Infiltration air\"   : \"infiltr_air_bin\",\n",
        "    \"Infiltration eau\"   : \"infiltr_eau_bin\",\n",
        "    \"Humidité\"           : \"humidite_bin\",\n",
        "    \"Courants froids\"    : \"courants_froids_bin\",\n",
        "    \"Vitrage simple\"     : \"vitrage_simple_bin\",\n",
        "    \"État volets\"        : \"volet_etat_num\",\n",
        "    \"État toiture\"       : \"toiture_etat_num\",\n",
        "    \"Superficie\"         : \"superficie\",\n",
        "    \"Étage\"              : \"etage\",\n",
        "}\n",
        "\n",
        "rows_f3 = []\n",
        "for lbl, col in corr_vars.items():\n",
        "    tmp = df_cl[[\"score_confort\", col]].dropna()\n",
        "    r, p = spearmanr(tmp[\"score_confort\"], tmp[col])\n",
        "    rows_f3.append({\"Variable\": lbl, \"r\": round(r,3), \"p_brut\": round(p,4)})\n",
        "\n",
        "f3_df  = pd.DataFrame(rows_f3)\n",
        "reject3, p_fdr3, _, _ = multipletests(f3_df[\"p_brut\"].values, method=\"fdr_bh\")\n",
        "f3_df[\"p_FDR\"]   = p_fdr3.round(4)\n",
        "f3_df[\"sig_brut\"] = f3_df[\"p_brut\"].apply(\n",
        "    lambda p: \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"ns\")))\n",
        "f3_df[\"sig_FDR\"]  = f3_df[\"p_FDR\"].apply(\n",
        "    lambda p: \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"ns\")))\n",
        "\n",
        "print(f\"\\n{'Variable':<25} {'r':>6} {'p_brut':>8} {'p_FDR':>8} \"\n",
        "      f\"{'Sig_brut':>9} {'Sig_FDR':>8}\")\n",
        "print(\"─\"*68)\n",
        "for _, row in f3_df.sort_values(\"r\", key=abs, ascending=False).iterrows():\n",
        "    changed = \" ←\" if row[\"sig_brut\"] != row[\"sig_FDR\"] else \"\"\n",
        "    print(f\"{row['Variable']:<25} {row['r']:>6.3f} {row['p_brut']:>8.4f} \"\n",
        "          f\"{row['p_FDR']:>8.4f} {row['sig_brut']:>9} {row['sig_FDR']:>8}{changed}\")\n",
        "\n",
        "n_changed3 = (f3_df[\"sig_brut\"] != f3_df[\"sig_FDR\"]).sum()\n",
        "print(f\"\\n→ {n_changed3} corrélations changent après correction FDR\")\n",
        "\n",
        "# ── TABLEAU RÉCAPITULATIF POUR L'ARTICLE ─────────────────────────────────\n",
        "print(f\"\\n{'='*65}\")\n",
        "print(\"TABLEAU RÉCAPITULATIF — POUR L'ARTICLE\")\n",
        "print(\"=\"*65)\n",
        "print(\"\"\"\n",
        "Famille   Tests               N tests  Correction        α effectif\n",
        "───────────────────────────────────────────────────────────────────\n",
        "F0        Kruskal-Wallis      1/var    Aucune (omnibus)  0.05\n",
        "F1        Post-hoc MWU k=4    6        Bonferroni        0.008\n",
        "F2        V de Cramér         28       FDR (BH)          variable\n",
        "F3        Spearman            12       FDR (BH)          variable\n",
        "F4        Logit ordinal été   1 modèle Aucune (global)   0.05 par OR\n",
        "F4        Logit ordinal hiver 1 modèle Aucune (global)   0.05 par OR\n",
        "\"\"\")\n",
        "\n",
        "print(\"\"\"\n",
        "FORMULATION POUR L'ARTICLE (section 3) :\n",
        "\n",
        "\"Multiple comparison corrections were applied separately within\n",
        "each inferential family. The Kruskal-Wallis test was used as a\n",
        "global omnibus test requiring no correction (one hypothesis per\n",
        "variable). Post-hoc pairwise comparisons (Mann-Whitney U, six\n",
        "pairs for k=4) were corrected using the Bonferroni method\n",
        "(α_adjusted = 0.05/6 = 0.008). The 28 Cramér's V coefficients\n",
        "and 12 Spearman correlations were treated as two independent\n",
        "exploratory families, each corrected using the Benjamini-Hochberg\n",
        "false discovery rate (FDR) procedure (Benjamini & Hochberg, 1995)\n",
        "to balance Type I error control with statistical power. Ordinal\n",
        "logistic regression models were treated as single inferential\n",
        "procedures; no additional correction was applied to individual\n",
        "coefficient p-values beyond the model-level significance.\"\n",
        "\"\"\")"
      ],
      "metadata": {
        "id": "FWJrEMSlxqRo"
      },
      "execution_count": null,
      "outputs": []
    },
