        "\n",
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 6 — Figures profils (effectifs cohérents N=116)               ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "colors4 = [PAL[i] for i in range(CHOSEN_K)]\n",
        "cl_labels = [f\"C{i}\\n(n={(df_cl['cluster']==i).sum()})\" for i in range(CHOSEN_K)]\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "fig.suptitle(f\"Figure 3 — Profils thermo-comportementaux des 4 clusters\\n\"\n",
        "             f\"(N={N_ref} — base ACM cohérente)\",\n",
        "             fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "# A) Score de confort — violon\n",
        "data_vio = [df_cl[df_cl[\"cluster\"]==cl][\"score_confort\"].dropna().values\n",
        "            for cl in range(CHOSEN_K)]\n",
        "vp = axes[0,0].violinplot(data_vio, positions=range(CHOSEN_K),\n",
        "                           showmedians=True, showmeans=False)\n",
        "for body, col in zip(vp[\"bodies\"], colors4):\n",
        "    body.set_facecolor(col); body.set_alpha(0.65)\n",
        "vp[\"cmedians\"].set_color(\"white\"); vp[\"cmedians\"].set_lw(2.5)\n",
        "np.random.seed(42)\n",
        "for i, (data, col) in enumerate(zip(data_vio, colors4)):\n",
        "    jitter = np.random.uniform(-0.07, 0.07, len(data))\n",
        "    axes[0,0].scatter(i+jitter, data, color=col, s=15, alpha=0.4, zorder=3)\n",
        "    axes[0,0].scatter(i, np.mean(data), color=\"white\", marker=\"D\",\n",
        "                      s=60, zorder=5, edgecolors=col, lw=1.5)\n",
        "axes[0,0].set_xticks(range(CHOSEN_K))\n",
        "axes[0,0].set_xticklabels(cl_labels, fontsize=8)\n",
        "axes[0,0].set_ylabel(\"Score de confort (0–10)\")\n",
        "axes[0,0].set_title(\"A) Score de confort (violon + points)\\n◆ = moyenne\")\n",
        "axes[0,0].set_ylim(-0.5, 11.5)\n",
        "\n",
