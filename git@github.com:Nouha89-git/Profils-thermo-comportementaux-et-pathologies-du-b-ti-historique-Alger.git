    {
      "cell_type": "code",
      "source": [
        "\"\"\"\n",
        "OBJECTIF : Après le test de Kruskal-Wallis global, identifier\n",
        "QUELLES paires de clusters diffèrent significativement.\n",
        "Requis par les reviewers Q1 pour valider les profils.\n",
        "\"\"\"\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from scipy.stats import mannwhitneyu\n",
        "from itertools import combinations\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"TESTS POST-HOC — Comparaisons par paires (Dunn / MWU)\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "df_cl = df.dropna(subset=[\"cluster\"]).copy()\n",
        "df_cl[\"cluster\"] = df_cl[\"cluster\"].astype(int)\n",
        "\n",
        "# Variables continues à tester\n",
        "cont_vars = {\n",
        "    \"Score de confort\"   : \"score_confort\",\n",
        "    \"Satisfaction été\"   : \"sat_ete_num\",\n",
        "    \"Satisfaction hiver\" : \"sat_hiver_num\",\n",
        "    \"Sensation thermique\": \"sensation_num\",\n",
        "    \"Superficie\"         : \"superficie\",\n",
        "    \"Étage\"              : \"etage\",\n",
        "}\n",
        "\n",
        "pairs = list(combinations(range(3), 2))\n",
        "pair_labels = {(0,1):\"C0 vs C1\", (0,2):\"C0 vs C2\", (1,2):\"C1 vs C2\"}\n",
        "\n",
        "print(f\"\\n{'Variable':<24}\", end=\"\")\n",
        "for p in pairs:\n",
        "    print(f\"  {pair_labels[p]:>12}\", end=\"\")\n",
        "print()\n",
        "print(\"─\" * 65)\n",
        "\n",
        "posthoc_results = []\n",
        "for label, col in cont_vars.items():\n",
        "    print(f\"{label:<24}\", end=\"\")\n",
        "    row = {\"Variable\": label}\n",
        "    for p in pairs:\n",
        "        g1 = df_cl[df_cl[\"cluster\"]==p[0]][col].dropna()\n",
        "        g2 = df_cl[df_cl[\"cluster\"]==p[1]][col].dropna()\n",
        "        if len(g1) > 1 and len(g2) > 1:\n",
        "            u, p_val = mannwhitneyu(g1, g2, alternative=\"two-sided\")\n",
        "            # Correction de Bonferroni (3 comparaisons)\n",
        "            p_bon = min(p_val * 3, 1.0)\n",
        "            sig = \"***\" if p_bon<0.001 else (\"**\" if p_bon<0.01 else (\"*\" if p_bon<0.05 else \"ns\"))\n",
        "            row[pair_labels[p]] = f\"p={p_bon:.3f} {sig}\"\n",
        "            print(f\"  {sig:>12}\", end=\"\")\n",
        "        else:\n",
        "            row[pair_labels[p]] = \"n/a\"\n",
        "            print(f\"  {'n/a':>12}\", end=\"\")\n",
        "    posthoc_results.append(row)\n",
        "    print()\n",
        "\n",
        "posthoc_df = pd.DataFrame(posthoc_results)\n",
        "print(\"\\n(p corrigé Bonferroni, *** p<0.001, ** p<0.01, * p<0.05, ns non significatif)\")\n",
        "\n",
        "# ── Figure : Violons par cluster pour le score de confort ─────────────────\n",
        "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
        "fig.suptitle(\"Figure Q6 — Distributions par cluster\\n\"\n",
        "             \"Tests post-hoc (Mann-Whitney, correction Bonferroni)\",\n",
        "             fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "PAL_colors = [\"#185FA5\", \"#D85A30\", \"#3C9E6E\"]\n",
        "plot_vars  = [(\"Score de confort\", \"score_confort\"),\n",
        "              (\"Satisfaction été\", \"sat_ete_num\"),\n",
        "              (\"Satisfaction hiver\", \"sat_hiver_num\")]\n",
        "\n",
        "for ax, (label, col) in zip(axes, plot_vars):\n",
        "    data_plot = [df_cl[df_cl[\"cluster\"]==cl][col].dropna().values for cl in range(3)]\n",
        "    vp = ax.violinplot(data_plot, positions=[0,1,2], showmedians=True, showmeans=False)\n",
        "    for i, (body, color) in enumerate(zip(vp[\"bodies\"], PAL_colors)):\n",
        "        body.set_facecolor(color); body.set_alpha(0.6)\n",
        "    vp[\"cmedians\"].set_color(\"white\"); vp[\"cmedians\"].set_lw(2)\n",
        "\n",
        "    # Ajouter les n\n",
        "    for i in range(3):\n",
        "        ax.text(i, ax.get_ylim()[0] if ax.get_ylim()[0] > -5 else -2.8,\n",
        "                f\"n={len(data_plot[i])}\", ha=\"center\", fontsize=8, color=\"grey\")\n",
        "\n",
        "    ax.set_xticks([0,1,2])\n",
        "    ax.set_xticklabels([\"C0\\nPassif\", \"C1\\nConfort\", \"C2\\nInconfort\"])\n",
        "    ax.set_ylabel(label)\n",
        "    ax.set_title(label)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/Q6_posthoc.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"\\n✓ Figure Q6 — Tests post-hoc sauvegardée\")"
      ],
