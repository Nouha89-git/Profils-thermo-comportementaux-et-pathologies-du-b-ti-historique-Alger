        "import numpy as np\n",
        "from scipy import stats\n",
        "from sklearn.metrics import silhouette_score, davies_bouldin_score, calinski_harabasz_score\n",
        "\n",
        "print(\"\\n\" + \"=\" * 65)\n",
        "print(\"RÉSUMÉ STATISTIQUE COMPLET — POUR L'ARTICLE Q1\")\n",
        "print(\"=\" * 65)\n",
        "\n",
        "df_cl = df.dropna(subset=[\"cluster\"]).copy()\n",
        "df_cl[\"cluster\"] = df_cl[\"cluster\"].astype(int)\n",
        "\n",
        "cum_pct = np.cumsum(exp_pct)\n",
        "\n",
        "# Calculate H and p_kruskal\n",
        "groups_kruskal = [df_cl[df_cl['cluster']==c]['score_confort'].dropna() for c in range(3)]\n",
        "H, p_kruskal = stats.kruskal(*groups_kruskal)\n",
        "\n",
        "print(f\"\"\"\n",
        "SECTION 3 — MÉTHODES\n",
