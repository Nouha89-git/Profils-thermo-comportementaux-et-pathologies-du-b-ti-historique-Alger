      "cell_type": "code",
      "source": [
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 7 — Analyse Discriminante Linéaire (LDA)                     ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "lda_feats = {\n",
        "    \"Infiltration air\"   : \"infiltr_air_bin\",\n",
        "    \"Infiltration eau\"   : \"infiltr_eau_bin\",\n",
        "    \"Humidité\"           : \"humidite_bin\",\n",
        "    \"Courants froids\"    : \"courants_froids_bin\",\n",
        "    \"Vitrage simple\"     : \"vitrage_simple_bin\",\n",
        "    \"État volets\"        : \"volet_etat_num\",\n",
        "    \"État toiture\"       : \"toiture_etat_num\",\n",
        "    \"Fan/clim (été)\"     : \"beh_fan_ac\",\n",
        "    \"Volets (été)\"       : \"beh_volets_ete\",\n",
        "    \"Chauffage (hiver)\"  : \"beh_chauffage\",\n",
        "    \"Vêts chauds\"        : \"beh_vets_chauds\",\n",
        "    \"Superficie\"         : \"superficie\",\n",
        "    \"Étage\"              : \"etage\",\n",
        "}\n",
        "\n",
        "lda_df = df_cl[list(lda_feats.values()) + [\"cluster\"]].dropna()\n",
        "X_lda  = lda_df[list(lda_feats.values())].values\n",
        "y_lda  = lda_df[\"cluster\"].values\n",
        "print(f\"LDA : N={len(lda_df)} (après dropna variables LDA)\")\n",
        "\n",
        "lda    = LinearDiscriminantAnalysis()\n",
        "cv     = StratifiedKFold(n_splits=10, shuffle=True, random_state=42)\n",
        "cv_acc = cross_val_score(lda, X_lda, y_lda, cv=cv, scoring=\"accuracy\")\n",
        "y_pred = cross_val_predict(lda, X_lda, y_lda, cv=cv)\n",
        "lda.fit(X_lda, y_lda)\n",
        "\n",
        "print(f\"\\nLDA Accuracy CV-10 = {cv_acc.mean():.3f} ± {cv_acc.std():.3f}\")\n",
        "print(f\"Variance LD1       = {lda.explained_variance_ratio_[0]*100:.1f}%\")\n",
        "print(f\"Variance LD2       = {lda.explained_variance_ratio_[1]*100:.1f}%\")\n",
        "print(f\"\\nRapport classification (CV-10) :\")\n",
        "target_names = [f\"C{cl}\" for cl in range(CHOSEN_K)]\n",
        "print(classification_report(y_lda, y_pred, target_names=target_names))\n",
        "\n",
        "# Importance des variables (norme des coefficients discriminants)\n",
        "imp_lda = pd.DataFrame({\n",
        "    \"Feature\"    : list(lda_feats.keys()),\n",
        "    \"Importance\" : np.sqrt(np.sum(lda.coef_**2, axis=0))\n",
        "}).sort_values(\"Importance\", ascending=True)\n",
        "\n",
        "# ── Figure 5 : LDA ────────────────────────────────────────────────────────\n",
        "fig, axes = plt.subplots(1, 3, figsize=(17, 5))\n",
        "fig.suptitle(\"Figure 5 — Analyse Discriminante Linéaire (LDA, CV-10)\",\n",
        "             fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "X_proj = lda.transform(X_lda)\n",
        "for cl in range(CHOSEN_K):\n",
        "    mask = y_lda == cl\n",
        "    axes[0].scatter(X_proj[mask,0], X_proj[mask,1],\n",
        "                    color=PAL[cl], s=50, alpha=0.75,\n",
        "                    edgecolors=\"white\", lw=0.4,\n",
        "                    label=f\"C{cl} (n={mask.sum()})\")\n",
        "    axes[0].scatter(X_proj[mask,0].mean(), X_proj[mask,1].mean(),\n",
        "                    color=PAL[cl], marker=\"*\", s=250,\n",
        "                    zorder=6, edgecolors=\"black\", lw=0.5)\n",
        "axes[0].set_xlabel(\"LD1\"); axes[0].set_ylabel(\"LD2\")\n",
        "axes[0].set_title(f\"A) Plan discriminant LD1×LD2\\n\"\n",
        "                  f\"(Acc. CV-10 = {cv_acc.mean():.3f})\")\n",
        "axes[0].legend(fontsize=7)\n",
        "\n",
        "bars = axes[1].barh(imp_lda[\"Feature\"], imp_lda[\"Importance\"],\n",
        "                    color=\"#534AB7\", edgecolor=\"white\", alpha=0.85)\n",
        "for bar, v in zip(bars, imp_lda[\"Importance\"]):\n",
        "    axes[1].text(v+0.005, bar.get_y()+bar.get_height()/2,\n",
        "                 f\"{v:.3f}\", va=\"center\", fontsize=8)\n",
        "axes[1].set_xlabel(\"Importance discriminante (‖LD‖)\")\n",
        "axes[1].set_title(\"B) Variables discriminantes\")\n",
        "\n",
        "cm = confusion_matrix(y_lda, y_pred)\n",
        "sns.heatmap(cm, annot=True, fmt=\"d\", cmap=\"Blues\", ax=axes[2],\n",
        "            xticklabels=target_names, yticklabels=target_names,\n",
        "            annot_kws={\"size\":11})\n",
        "axes[2].set_xlabel(\"Prédit (CV-10)\"); axes[2].set_ylabel(\"Réel\")\n",
        "axes[2].set_title(\"C) Matrice de confusion\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/fig5_LDA.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"✓ Figure 5 — LDA\")"
      ],
      "metadata": {
        "colab": {
