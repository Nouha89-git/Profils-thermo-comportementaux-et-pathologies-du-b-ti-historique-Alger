      "cell_type": "code",
      "source": [
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 9 — Cramér's V avec seuils Cohen                             ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "def cramers_v(x, y):\n",
        "    ct = pd.crosstab(x, y)\n",
        "    chi2, p, dof, _ = chi2_contingency(ct)\n",
        "    n = ct.sum().sum()\n",
        "    r, k = ct.shape\n",
        "    v = np.sqrt(chi2 / (n * (min(r,k)-1)))\n",
        "    return round(v, 3), round(p, 4)\n",
        "\n",
        "df_cl[\"cluster_label\"] = df_cl[\"cluster\"].map(CLUSTER_NAMES)\n",
        "\n",
        "arch_vars = {\n",
        "    \"Type de vitrage\"  : \"vitrage_type\",\n",
        "    \"État volets\"      : \"volet_etat\",\n",
        "    \"État toiture\"     : \"toiture_etat\",\n",
        "    \"Infiltration air\" : \"infiltr_air\",\n",
        "    \"Infiltration eau\" : \"infiltr_eau\",\n",
        "    \"Humidité\"         : \"humidite\",\n",
        "    \"Courants froids\"  : \"courants_froids\",\n",
        "}\n",
        "target_vars = {\n",
        "    \"Sensation\"        : \"sensation\",\n",
        "    \"Satisfaction été\" : \"sat_ete\",\n",
        "    \"Sat. hiver\"       : \"sat_hiver\",\n",
        "    \"Cluster\"          : \"cluster_label\",\n",
        "}\n",
        "\n",
        "def cohen_label(v):\n",
        "    if v < 0.10: return \"nég.\"\n",
        "    elif v < 0.30: return \"petit\"\n",
        "    elif v < 0.50: return \"moyen\"\n",
        "    else: return \"grand\"\n",
        "\n",
        "cv_matrix = {}\n",
        "print(f\"\\n{'Variable':<22}\", end=\"\")\n",
        "for t in target_vars: print(f\"  {t:>16}\", end=\"\")\n",
        "print(); print(\"─\"*85)\n",
        "\n",
        "for arch_lbl, arch_col in arch_vars.items():\n",
        "    row = {}; print(f\"{arch_lbl:<22}\", end=\"\")\n",
        "    for tgt_lbl, tgt_col in target_vars.items():\n",
        "        tmp = df_cl[[arch_col, tgt_col]].dropna()\n",
        "        if len(tmp) > 10:\n",
        "            v, p = cramers_v(tmp[arch_col], tmp[tgt_col])\n",
        "            sig  = \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"ns\"))\n",
        "            eff  = cohen_label(v)\n",
        "            row[tgt_lbl] = v\n",
        "            print(f\"  {v:.2f}({eff}){sig:>3}\", end=\"\")\n",
        "        else:\n",
        "            row[tgt_lbl] = np.nan; print(f\"  {'n/a':>16}\", end=\"\")\n",
        "    cv_matrix[arch_lbl] = row; print()\n",
        "\n",
        "print(\"\\nSeuils Cohen : V<0.10=négligeable | 0.10–0.30=petit | 0.30–0.50=moyen | >0.50=grand\")\n",
        "print(\"⚠ Association ≠ Causalité (données transversales déclaratives)\")\n",
        "\n",
        "# ── Figure 7 : heatmap Cramér's V ─────────────────────────────────────────\n",
        "cv_df = pd.DataFrame(cv_matrix).T\n",
        "annot = cv_df.copy().astype(object)\n",
        "for i in range(cv_df.shape[0]):\n",
        "    for j in range(cv_df.shape[1]):\n",
        "        v = cv_df.iloc[i,j]\n",
        "        if pd.notna(v):\n",
        "            annot.iloc[i,j] = f\"{v:.2f}\\n({cohen_label(v)})\"\n",
        "        else:\n",
        "            annot.iloc[i,j] = \"n/a\"\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 6))\n",
        "sns.heatmap(cv_df.astype(float), annot=annot, fmt=\"\",\n",
        "            cmap=\"YlOrRd\", vmin=0, vmax=0.5, linewidths=0.5,\n",
        "            annot_kws={\"size\":8}, ax=ax,\n",
        "            cbar_kws={\"label\":\"Cramér's V\",\"shrink\":0.8})\n",
        "ax.set_title(\"Figure 7 — Cramér's V : association entre variables \"\n",
        "             \"architecturales et confort\\n\"\n",
        "             \"Seuils Cohen — ⚠ Association ≠ Causalité\",\n",
        "             fontsize=10, fontweight=\"bold\")\n",
        "ax.set_xticklabels(ax.get_xticklabels(), rotation=30, ha=\"right\")\n",
        "ax.set_yticklabels(ax.get_yticklabels(), rotation=0)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/fig7_cramers_v.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"✓ Figure 7 — Cramér's V\")"
      ],
