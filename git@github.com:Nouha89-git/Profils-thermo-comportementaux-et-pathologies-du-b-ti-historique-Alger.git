            "Variable                        r        p   Sig\n",
            "──────────────────────────────────────────────────\n",
            "Satisfaction hiver          0.458   0.0000   ***\n",
            "Satisfaction été            0.394   0.0000   ***\n",
            "Sensation thermique         0.326   0.0019    **\n",
            "Humidité/moisiss.          -0.247   0.0055    **\n",
            "Vitrage simple             -0.201   0.0246     *\n",
            "Toiture (état)              0.199   0.0258     *\n",
            "Vêts chauds (hiver)        -0.180   0.0450     *\n",
            "Volet (état)                0.174   0.0619    ns\n",
            "Fermer volets (été)        -0.174   0.0527    ns\n",
            "Infiltration air           -0.158   0.0786    ns\n",
            "Infiltration eau           -0.136   0.1302    ns\n",
            "Fermer fenêtres            -0.108   0.2323    ns\n",
            "Superficie                  0.081   0.3666    ns\n",
            "Courants froids            -0.070   0.4382    ns\n",
            "Ouvrir fenêtres             0.065   0.4685    ns\n",
            "Chauffage (hiver)          -0.057   0.5311    ns\n",
            "Fan/clim (été)             -0.035   0.7005    ns\n",
            "Étage                      -0.031   0.7292    ns\n"
          ]
        },
