            "         Superficie  -0.0111  0.0041      0.0118\n",
            "   Infiltration air  -0.2279  0.1499      0.2728\n",
            "              Étage  -0.1847 -0.2280      0.2934\n",
            "       État toiture   0.1485 -0.2771      0.3144\n",
            "           Humidité   0.4409 -0.9589      1.0554\n",
            "        État volets  -1.0271  0.5567      1.1683\n",
            "Fermer volets (été)  -0.8192 -1.3323      1.5640\n",
            "   Infiltration eau  -1.4592  1.0095      1.7744\n",
