            "Reference dataset: N=116 — coherent base for ALL figures\n",
            "ARI (CAH vs K-Means) = 0.5005\n",
            "  C0 — Passive-resigned: n=14 (12.1%)  comfort=6.43\n",
            "  C1 — Comfort-satisfied: n=14 (12.1%)  comfort=8.36\n",
            "  C2 — Severe discomfort: n=24 (20.7%)  comfort=5.12\n",
            "  C3 — Moderate discomfort: n=64 (55.2%)  comfort=6.48\n",
            "\n",
            "Kruskal-Wallis (omnibus — NO correction for omnibus test):\n",
            "  Comfort: H=23.837, p=0.0000 ***\n",
            "  Sat.Summer: H=34.174, p=0.0000 ***\n",
            "  Sat.Winter: H=59.145, p=0.0000 ***\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Bonferroni applies to POST-HOC pairs ONLY, NOT the omnibus Kruskal-Wallis\n",
        "pairs   = list(combinations(range(K4), 2))\n",
        "n_pairs = len(pairs)  # = 6\n",
        "\n",
        "print(f\"Post-hoc pairwise — Family F1\")\n",
        "print(f\"Bonferroni correction: alpha/6 = {0.05/n_pairs:.4f}\\n\")\n",
        "\n",
        "for lbl,col in [(\"Comfort score\",\"comfort_score\"),\n",
        "                 (\"Summer satisfaction\",\"sat_summer_n\"),\n",
        "                 (\"Winter satisfaction\",\"sat_winter_n\")]:\n",
        "    print(f\"  {lbl}:\")\n",
        "    p_raws, rows = [], []\n",
        "    for p0,p1 in pairs:\n",
        "        g0 = ref[ref[\"cluster\"]==p0][col].dropna()\n",
        "        g1 = ref[ref[\"cluster\"]==p1][col].dropna()\n",
        "        U,p = mannwhitneyu(g0, g1, alternative=\"two-sided\")\n",
        "        p_raws.append(p); rows.append((p0,p1,U,g0.mean(),g1.mean()))\n",
        "    _, p_bonf, _, _ = multipletests(p_raws, method=\"bonferroni\")\n",
        "    print(f\"  {'Pair':<12} {'U':>8} {'p_raw':>9} {'p_Bonf':>9} {'Sig':>5}\")\n",
        "    for (p0,p1,U,m0,m1),pb in zip(rows,p_bonf):\n",
        "        sig = \"***\" if pb<0.001 else \"**\" if pb<0.01 else \"*\" if pb<0.05 else \"ns\"\n",
        "        print(f\"  C{p0} vs C{p1}    {U:>8.0f} {p_raws[rows.index((p0,p1,U,m0,m1))]:>9.4f} \"\n",
        "              f\"{pb:>9.4f} {sig:>5}  (means: {m0:.2f} vs {m1:.2f})\")\n",
        "    print()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Ooa28ddzVY7S",
        "outputId": "5146d5f6-d5c8-41e7-833c-3fd48fd9eeeb"
      },
      "execution_count": 13,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Post-hoc pairwise — Family F1\n",
            "Bonferroni correction: alpha/6 = 0.0083\n",
            "\n",
            "  Comfort score:\n",
            "  Pair                U     p_raw    p_Bonf   Sig\n",
            "  C0 vs C1          44    0.0121    0.0729    ns  (means: 6.43 vs 8.36)\n",
            "  C0 vs C2         230    0.0605    0.3628    ns  (means: 6.43 vs 5.12)\n",
            "  C0 vs C3         438    0.8939    1.0000    ns  (means: 6.43 vs 6.48)\n",
            "  C1 vs C2         296    0.0001    0.0006   ***  (means: 8.36 vs 5.12)\n",
            "  C1 vs C3         710    0.0005    0.0030    **  (means: 8.36 vs 6.48)\n",
            "  C2 vs C3         424    0.0010    0.0059    **  (means: 5.12 vs 6.48)\n",
            "\n",
            "  Summer satisfaction:\n",
            "  Pair                U     p_raw    p_Bonf   Sig\n",
