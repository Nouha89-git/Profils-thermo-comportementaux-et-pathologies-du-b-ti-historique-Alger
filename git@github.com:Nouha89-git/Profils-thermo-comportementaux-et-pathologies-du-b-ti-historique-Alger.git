        "import matplotlib.pyplot as plt\n",
        "\n",
        "fig, axes = plt.subplots(2, 3, figsize=(16, 9))\n",
        "fig.suptitle(\"Profil des répondants et caractéristiques du logement (N=125)\",\n",
        "             fontsize=12, fontweight=\"bold\")\n",
        "\n",
        "# 1. Genre\n",
        "vc = df_raw[\"Gender\"].value_counts()\n",
        "axes[0,0].pie(vc.values, labels=vc.index, autopct=\"%1.1f%%\",\n",
        "              colors=[\"#185FA5\",\"#D85A30\",\"#3C9E6E\"], startangle=90)\n",
        "axes[0,0].set_title(\"Genre\")\n",
        "\n",
        "# 2. Statut occupant\n",
        "vc2 = df_raw[\"Occupant status\"].value_counts()\n",
        "axes[0,1].barh(vc2.index, vc2.values, color=\"#534AB7\", edgecolor=\"white\")\n",
        "for i, v in enumerate(vc2.values):\n",
        "    axes[0,1].text(v+0.3, i, f\"{v} ({100*v/len(df_raw):.1f}%)\", va=\"center\", fontsize=9)\n",
        "axes[0,1].set_title(\"Statut occupant\")\n",
        "axes[0,1].set_xlim(0, vc2.max()*1.3)\n",
        "\n",
        "# 3. Distribution des âges\n",
        "axes[0,2].hist(df[\"age\"].dropna(), bins=10, color=\"#3C9E6E\", edgecolor=\"white\")\n",
        "axes[0,2].axvline(df[\"age\"].mean(), color=\"red\", lw=1.5, linestyle=\"--\",\n",
        "                  label=f\"Moy={df['age'].mean():.1f} ans\")\n",
        "axes[0,2].set_xlabel(\"Âge\"); axes[0,2].set_title(\"Distribution des âges\")\n",
        "axes[0,2].legend()\n",
        "\n",
        "# 4. Superficie\n",
        "axes[1,0].hist(df[\"superficie\"].dropna(), bins=10, color=\"#D85A30\", edgecolor=\"white\")\n",
        "axes[1,0].axvline(df[\"superficie\"].mean(), color=\"blue\", lw=1.5, linestyle=\"--\",\n",
        "                  label=f\"Moy={df['superficie'].mean():.0f} m²\")\n",
        "axes[1,0].set_xlabel(\"Superficie (m²)\"); axes[1,0].set_title(\"Superficie des logements\")\n",
        "axes[1,0].legend()\n",
        "\n",
        "# 5. Étage\n",
        "vc3 = df[\"etage\"].value_counts().sort_index()\n",
        "axes[1,1].bar(vc3.index.astype(str), vc3.values, color=\"#185FA5\", edgecolor=\"white\")\n",
        "axes[1,1].set_xlabel(\"Étage\"); axes[1,1].set_title(\"Distribution des étages\")\n",
        "\n",
        "# 6. Orientation façade\n",
        "vc4 = df_raw[\"Facade orientation\"].value_counts().head(6)\n",
        "axes[1,2].barh(vc4.index, vc4.values, color=\"#BA7517\", edgecolor=\"white\")\n",
        "axes[1,2].set_title(\"Orientation façade principale\")\n",
        "\n",
