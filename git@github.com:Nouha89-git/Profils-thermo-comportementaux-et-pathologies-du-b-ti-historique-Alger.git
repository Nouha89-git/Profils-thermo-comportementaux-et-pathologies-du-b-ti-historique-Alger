    {
      "cell_type": "code",
      "source": [
        "\"\"\"\n",
        "OBJECTIF : Identifier les facteurs qui prédisent la satisfaction thermique.\n",
        "La régression logistique ordinale est la méthode standard pour les\n",
        "variables de réponse ordinales (satisfaction -2 à +2).\n",
        "Elle remplace le Random Forest qui donnait un R² trop faible.\n",
        "\"\"\"\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import statsmodels.formula.api as smf\n",
        "from statsmodels.miscmodels.ordinal_model import OrderedModel\n",
        "import matplotlib.pyplot as plt\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"RÉGRESSION LOGISTIQUE ORDINALE\")\n",
        "print(\"Prédire la satisfaction thermique (été + hiver)\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# ── Préparer les données ──────────────────────────────────────────────────\n",
        "reg_df = df[[\n",
        "    \"sat_ete_num\", \"sat_hiver_num\",\n",
        "    \"infiltr_air_bin\", \"infiltr_eau_bin\", \"humidite_bin\", \"courants_froids_bin\",\n",
        "    \"vitrage_simple_bin\", \"volet_etat_num\", \"toiture_etat_num\",\n",
        "    \"beh_fan_ac\", \"beh_volets_ete\", \"beh_fen_ouv\",\n",
        "    \"beh_chauffage\", \"beh_vets_chauds\", \"beh_fen_ferm\",\n",
        "    \"superficie\", \"etage\",\n",
        "]].dropna().copy()\n",
        "\n",
        "print(f\"N disponible pour régression : {len(reg_df)}\")\n",
        "\n",
        "# ── A) Modèle pour satisfaction ÉTÉ ──────────────────────────────────────\n",
        "print(\"\\n── A) Satisfaction été ──\")\n",
        "\n",
        "# Convertir en catégorie ordonnée\n",
        "reg_df[\"sat_ete_cat\"] = pd.Categorical(\n",
        "    reg_df[\"sat_ete_num\"].astype(int),\n",
        "    categories=[-2, -1, 0, 1, 2],\n",
        "    ordered=True\n",
        ")\n",
        "\n",
        "X_cols = [\"infiltr_air_bin\", \"infiltr_eau_bin\", \"courants_froids_bin\",\n",
        "          \"vitrage_simple_bin\", \"volet_etat_num\", \"toiture_etat_num\",\n",
        "          \"beh_fan_ac\", \"beh_volets_ete\", \"superficie\"]\n",
        "\n",
        "X_ete = reg_df[X_cols].astype(float)\n",
        "y_ete = reg_df[\"sat_ete_cat\"]\n",
        "\n",
        "model_ete = OrderedModel(y_ete, X_ete, distr=\"logit\")\n",
        "result_ete = model_ete.fit(method=\"bfgs\", disp=False)\n",
        "\n",
        "print(result_ete.summary())\n",
        "\n",
        "# ── B) Modèle pour satisfaction HIVER ────────────────────────────────────\n",
        "print(\"\\n── B) Satisfaction hiver ──\")\n",
        "\n",
        "reg_df[\"sat_hiver_cat\"] = pd.Categorical(\n",
        "    reg_df[\"sat_hiver_num\"].astype(int),\n",
        "    categories=[-2, -1, 0, 1, 2],\n",
        "    ordered=True\n",
        ")\n",
        "\n",
        "X_cols_h = [\"infiltr_air_bin\", \"humidite_bin\", \"courants_froids_bin\",\n",
        "             \"vitrage_simple_bin\", \"volet_etat_num\", \"toiture_etat_num\",\n",
        "             \"beh_chauffage\", \"beh_vets_chauds\", \"superficie\"]\n",
        "\n",
        "X_hiver = reg_df[X_cols_h].astype(float)\n",
        "y_hiver = reg_df[\"sat_hiver_cat\"]\n",
        "\n",
        "model_hiver = OrderedModel(y_hiver, X_hiver, distr=\"logit\")\n",
        "result_hiver = model_hiver.fit(method=\"bfgs\", disp=False)\n",
        "\n",
        "print(result_hiver.summary())\n",
        "\n",
        "# ── C) Figure : Odds Ratios des deux modèles ─────────────────────────────\n",
        "var_labels = {\n",
        "    \"infiltr_air_bin\"     : \"Infiltration air\",\n",
        "    \"infiltr_eau_bin\"     : \"Infiltration eau\",\n",
        "    \"humidite_bin\"        : \"Humidité/moisissures\",\n",
        "    \"courants_froids_bin\" : \"Courants froids\",\n",
        "    \"vitrage_simple_bin\"  : \"Vitrage simple\",\n",
        "    \"volet_etat_num\"      : \"État volets\",\n",
        "    \"toiture_etat_num\"    : \"État toiture\",\n",
        "    \"beh_fan_ac\"          : \"Fan/clim (été)\",\n",
        "    \"beh_volets_ete\"      : \"Fermer volets (été)\",\n",
        "    \"beh_chauffage\"       : \"Chauffage (hiver)\",\n",
        "    \"beh_vets_chauds\"     : \"Vêts chauds (hiver)\",\n",
        "    \"superficie\"          : \"Superficie (m²)\",\n",
        "}\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
        "fig.suptitle(\"Figure Q4 — Régression Logistique Ordinale\\n\"\n",
        "             \"Odds Ratios (IC 95%) — Satisfaction thermique\",\n",
        "             fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "for ax, result, xcols, title, color in [\n",
        "    (axes[0], result_ete,   X_cols,   \"A) Satisfaction Été\",   \"#D85A30\"),\n",
        "    (axes[1], result_hiver, X_cols_h, \"B) Satisfaction Hiver\", \"#185FA5\"),\n",
        "]:\n",
        "    params = result.params[xcols]\n",
        "    conf   = result.conf_int().loc[xcols]\n",
        "    pvals  = result.pvalues[xcols]\n",
        "\n",
        "    or_vals  = np.exp(params)\n",
        "    or_lower = np.exp(conf.iloc[:, 0])\n",
        "    or_upper = np.exp(conf.iloc[:, 1])\n",
        "\n",
        "    labels = [var_labels.get(c, c) for c in xcols]\n",
        "    y_pos  = range(len(labels))\n",
        "\n",
        "    # Trier par OR\n",
        "    sort_idx = np.argsort(or_vals.values)\n",
        "    or_s = or_vals.values[sort_idx]\n",
        "    lo_s = or_lower.values[sort_idx]\n",
        "    hi_s = or_upper.values[sort_idx]\n",
        "    lb_s = [labels[i] for i in sort_idx]\n",
        "    pv_s = pvals.values[sort_idx]\n",
        "\n",
        "    bar_colors = [color if p < 0.05 else \"#cccccc\" for p in pv_s]\n",
        "\n",
        "    ax.barh(range(len(lb_s)), or_s - 1, left=1,\n",
        "            color=bar_colors, edgecolor=\"white\", alpha=0.8, height=0.6)\n",
        "    ax.errorbar(or_s, range(len(lb_s)),\n",
        "                xerr=[or_s - lo_s, hi_s - or_s],\n",
        "                fmt=\"none\", color=\"black\", capsize=4, lw=1.2)\n",
        "    ax.axvline(1, color=\"black\", lw=1.2, linestyle=\"--\")\n",
        "    ax.set_yticks(range(len(lb_s)))\n",
        "    ax.set_yticklabels(lb_s, fontsize=8)\n",
        "    ax.set_xlabel(\"Odds Ratio (OR)\")\n",
        "    ax.set_title(title)\n",
        "\n",
        "    # Ajouter étoiles\n",
        "    for i, (ov, p) in enumerate(zip(or_s, pv_s)):\n",
        "        sig = \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"\"))\n",
        "        if sig:\n",
        "            ax.text(max(hi_s) + 0.05, i, sig, va=\"center\", fontsize=9, color=\"black\")\n",
        "\n",
        "    note = \"(barres grises = non significatif, p≥0.05)\"\n",
        "    ax.set_title(f\"{title}\\n{note}\", fontsize=9)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/Q4_ordinal_logistic.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"\\n✓ Figure Q4 — Régression logistique ordinale sauvegardée\")\n",
        "\n",
        "# ── D) Pseudo-R² et qualité du modèle ────────────────────────────────────\n",
        "print(\"\\nQualité des modèles :\")\n",
        "print(f\"  Satisfaction été   — Pseudo-R² (McFadden) = \"\n",
        "      f\"{1 - result_ete.llf/result_ete.llnull:.4f}\")\n",
        "print(f\"  Satisfaction hiver — Pseudo-R² (McFadden) = \"\n",
        "      f\"{1 - result_hiver.llf/result_hiver.llnull:.4f}\")\n",
        "print(\"\\nNote : Pseudo-R² de McFadden entre 0.10 et 0.20 indique un bon ajustement\")\n",
        "print(\"       pour une régression logistique ordinale (Louvière et al., 2000).\")"
      ],
