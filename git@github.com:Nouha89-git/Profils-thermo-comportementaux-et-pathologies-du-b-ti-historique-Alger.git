     \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"vitrage_simple_bin\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.10488088481701513,\n        \"min\": 0.78,\n        \"max\": 1.0,\n        \"num_unique_values\": 4,\n        \"samples\": [\n          0.79,\n          0.78,\n          1.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"beh_fan_ac\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.10115993936995678,\n        \"min\": 0.64,\n        \"max\": 0.84,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          0.64,\n          0.84,\n          0.78\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"beh_volets_ete\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.14282856857085702,\n        \"min\": 0.0,\n        \"max\": 0.3,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          0.14,\n          0.0,\n          0.3\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"beh_fen_ouv\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.09201449161228173,\n        \"min\": 0.3,\n        \"max\": 0.5,\n        \"num_unique_values\": 4,\n        \"samples\": [\n          0.5,\n          0.33,\n          0.43\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"beh_chauffage\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.4681167945431282,\n        \"min\": 0.0,\n        \"max\": 0.98,\n        \"num_unique_values\": 4,\n        \"samples\": [\n          0.93,\n          0.89,\n          0.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"beh_vets_chauds\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.3176476034853718,\n        \"min\": 0.05,\n        \"max\": 0.71,\n        \"num_unique_values\": 4,\n        \"samples\": [\n          0.07,\n          0.11,\n          0.71\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"beh_fen_ferm\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.40232656718972293,\n        \"min\": 0.14,\n        \"max\": 1.0,\n        \"num_unique_values\": 4,\n        \"samples\": [\n          0.14,\n          0.22,\n          1.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
