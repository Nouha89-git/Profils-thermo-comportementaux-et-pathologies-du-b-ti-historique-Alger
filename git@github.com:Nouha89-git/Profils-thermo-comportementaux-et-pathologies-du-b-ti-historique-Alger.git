        "    \"fig09_cluster_profiles\",       \"fig10_bootstrap_stability\",\n",
        "    \"fig11_cramers_v\",              \"fig12_spearman_correlations\",\n",
        "    \"fig13_LDA\",                    \"fig14_odds_ratios\",\n",
        "]\n",
        "for name in figures:\n",
        "    path = f\"/content/{name}.jpg\"\n",
        "    if os.path.exists(path):\n",
        "        files.download(path)\n",
        "        print(f\"downloaded: {name}.jpg\")\n",
        "    else:\n",
        "        print(f\"NOT FOUND: {name}.jpg — re-run the corresponding cell first\")"
      ],
