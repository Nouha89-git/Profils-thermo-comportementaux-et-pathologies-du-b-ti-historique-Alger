    {
      "cell_type": "code",
      "source": [
        "from scipy.stats import chi2_contingency\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "def cramers_v(x, y):\n",
        "    ct = pd.crosstab(x, y)\n",
        "    chi2, _, _, _ = chi2_contingency(ct)\n",
        "    n = ct.sum().sum()\n",
        "    r, k = ct.shape\n",
        "    return np.sqrt(chi2 / (n * (min(r, k) - 1)))\n",
        "\n",
        "# Variables architecturales à tester\n",
        "arch_vars = {\n",
        "    \"Type de vitrage\"      : \"vitrage_type\",\n",
        "    \"État des volets\"      : \"volet_etat\",\n",
        "    \"État de la toiture\"   : \"toiture_etat\",\n",
        "    \"Matériau fenêtres\"    : \"mat_fenetres\",\n",
        "    \"Orientation façade\"   : \"orientation\",\n",
        "    \"Dernier étage\"        : \"dernier_etage\",\n",
        "    \"Infiltration air\"     : \"infiltr_air\",\n",
        "    \"Infiltration eau\"     : \"infiltr_eau\",\n",
        "    \"Humidité/moisissures\" : \"humidite\",\n",
        "    \"Courants froids\"      : \"courants_froids\",\n",
        "}\n",
        "\n",
        "# Variables cibles à croiser\n",
        "target_vars = {\n",
        "    \"Sensation thermique\" : \"sensation\",\n",
        "    \"Satisfaction été\"    : \"sat_ete\",\n",
        "    \"Satisfaction hiver\"  : \"sat_hiver\",\n",
        "    \"Cluster CAH\"         : \"cluster_label\",\n",
        "}\n",
        "\n",
        "# Ajouter cluster au df\n",
        "df.loc[acm_raw.index, \"cluster_label\"] = [cluster_names[c] for c in cah_lab]\n",
        "\n",
        "# Calculer Cramér's V pour chaque paire\n",
        "results = {}\n",
        "for arch_label, arch_col in arch_vars.items():\n",
        "    row = {}\n",
        "    for tgt_label, tgt_col in target_vars.items():\n",
        "        tmp = df[[arch_col, tgt_col]].dropna()\n",
        "        if len(tmp) > 10:\n",
        "            try:\n",
        "                v = cramers_v(tmp[arch_col], tmp[tgt_col])\n",
        "                row[tgt_label] = round(v, 3)\n",
        "            except:\n",
        "                row[tgt_label] = np.nan\n",
        "        else:\n",
        "            row[tgt_label] = np.nan\n",
        "    results[arch_label] = row\n",
        "\n",
        "cv_df = pd.DataFrame(results).T\n",
        "print(\"Tableau Cramér's V :\")\n",
        "print(cv_df.to_string())\n",
        "\n",
        "# Heatmap Cramér's V\n",
        "fig, ax = plt.subplots(figsize=(9, 7))\n",
        "sns.heatmap(cv_df, annot=True, fmt=\".2f\", cmap=\"YlOrRd\",\n",
        "            vmin=0, vmax=0.5, linewidths=0.5,\n",
        "            annot_kws={\"size\": 10}, ax=ax,\n",
        "            cbar_kws={\"label\": \"Cramér's V\", \"shrink\": 0.8})\n",
        "ax.set_title(\"Cramér's V — Association entre variables architecturales\\n\"\n",
        "             \"et confort thermique / clusters\\n\"\n",
        "             \"(0 = aucune association, 1 = association parfaite)\",\n",
        "             fontsize=11, fontweight=\"bold\")\n",
        "ax.set_xlabel(\"Variable cible\")\n",
        "ax.set_ylabel(\"Variable architecturale / enveloppe\")\n",
        "ax.set_xticklabels(ax.get_xticklabels(), rotation=30, ha=\"right\")\n",
        "ax.set_yticklabels(ax.get_yticklabels(), rotation=0)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/D_cramers_v.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"✓ Figure D — Cramér's V\")\n",
        "\n",
        "# Interprétation\n",
        "print(\"\\nInterprétation des seuils Cramér's V :\")\n",
        "print(\"  V < 0.10 : association négligeable\")\n",
        "print(\"  0.10 ≤ V < 0.20 : association faible\")\n",
        "print(\"  0.20 ≤ V < 0.40 : association modérée\")\n",
        "print(\"  V ≥ 0.40 : association forte\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 1000
        },
