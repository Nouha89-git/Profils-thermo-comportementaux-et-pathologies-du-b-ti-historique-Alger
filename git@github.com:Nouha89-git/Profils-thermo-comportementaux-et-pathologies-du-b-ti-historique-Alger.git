          "text": [
            "✓ Figure 2 — Indices de validation\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 5 — CAH k=4 + profils                                        ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "CHOSEN_K = 4\n",
        "\n",
        "cah_lab = fcluster(Z_link, t=CHOSEN_K, criterion=\"maxclust\") - 1\n",
        "km_lab  = KMeans(n_clusters=CHOSEN_K, random_state=42, n_init=20).fit_predict(X_clust)\n",
        "\n",
        "# Noms des clusters (basés sur les profils observés)\n",
        "CLUSTER_NAMES = {\n",
        "    0: \"C0 — Passif résigné\",\n",
        "    1: \"C1 — Confort satisfait\",\n",
        "    2: \"C2 — Inconfort sévère\",\n",
        "    3: \"C3 — Inconfort modéré\",\n",
        "}\n",
        "\n",
        "# Attacher au dataframe de référence\n",
        "df_cl = acm_raw.copy()\n",
        "df_cl[\"cluster\"] = cah_lab\n",
        "# Récupérer les variables de confort depuis df\n",
        "for col in [\"score_confort\",\"sat_ete_num\",\"sat_hiver_num\",\"sensation_num\",\n",
        "            \"infiltr_air_bin\",\"infiltr_eau_bin\",\"humidite_bin\",\"courants_froids_bin\",\n",
        "            \"vitrage_simple_bin\",\"volet_etat_num\",\"toiture_etat_num\",\n",
        "            \"beh_fan_ac\",\"beh_volets_ete\",\"beh_fen_ouv\",\n",
        "            \"beh_chauffage\",\"beh_vets_chauds\",\"beh_fen_ferm\",\n",
        "            \"superficie\",\"etage\",\"volet_etat\",\"toiture_etat\",\n",
        "            \"vitrage_type\",\"infiltr_air\",\"infiltr_eau\",\"humidite\",\"courants_froids\",\n",
        "            \"sensation\",\"sat_ete\",\"sat_hiver\"]:\n",
        "    if col in df.columns:\n",
        "        df_cl[col] = df.loc[acm_raw.index, col].values\n",
        "\n",
        "N_ref = len(df_cl)\n",
        "print(f\"Base de référence : N={N_ref} (cohérente pour toutes les figures)\")\n",
        "print(f\"\\nDistribution des clusters :\")\n",
        "for cl in range(CHOSEN_K):\n",
        "    n = (df_cl[\"cluster\"]==cl).sum()\n",
        "    print(f\"  {CLUSTER_NAMES[cl]} : n={n} ({100*n/N_ref:.1f}%)\")\n",
        "\n",
        "print(f\"\\nSilhouette k=4  = {silhouette_score(X_clust, cah_lab):.4f}\")\n",
        "print(f\"Davies-Bouldin  = {davies_bouldin_score(X_clust, cah_lab):.4f}\")\n",
        "print(f\"Calinski-H      = {calinski_harabasz_score(X_clust, cah_lab):.2f}\")\n",
        "print(f\"ARI (CAH/KM)    = {adjusted_rand_score(cah_lab, km_lab):.4f}\")\n",
        "\n",
        "# ── Profils détaillés ─────────────────────────────────────────────────────\n",
        "print(\"\\n── Profils thermo-comportementaux (k=4) ──\")\n",
        "print(f\"{'Variable':<28}\", end=\"\")\n",
        "for cl in range(CHOSEN_K): print(f\"  C{cl}(n={(df_cl['cluster']==cl).sum():2d})\", end=\"\")\n",
        "print()\n",
        "print(\"─\"*65)\n",
        "\n",
        "profile_vars = {\n",
        "    \"Confort global (0–10)\" : \"score_confort\",\n",
        "    \"Satisfaction été\"      : \"sat_ete_num\",\n",
        "    \"Satisfaction hiver\"    : \"sat_hiver_num\",\n",
        "    \"Sensation thermique\"   : \"sensation_num\",\n",
        "    \"Infiltration air (%)\"  : \"infiltr_air_bin\",\n",
        "    \"Courants froids (%)\"   : \"courants_froids_bin\",\n",
        "    \"Humidité (%)\"          : \"humidite_bin\",\n",
        "    \"Vitrage simple (%)\"    : \"vitrage_simple_bin\",\n",
        "    \"Fan/clim été (%)\"      : \"beh_fan_ac\",\n",
        "    \"Chauffage hiver (%)\"   : \"beh_chauffage\",\n",
        "}\n",
        "\n",
        "for label, col in profile_vars.items():\n",
        "    print(f\"{label:<28}\", end=\"\")\n",
        "    for cl in range(CHOSEN_K):\n",
        "        sub = df_cl[df_cl[\"cluster\"]==cl][col].dropna()\n",
        "        val = sub.mean()\n",
        "        if \"%\" in label:\n",
        "            print(f\"  {val*100:>7.1f}%\", end=\"\")\n",
        "        else:\n",
        "            print(f\"  {val:>8.2f}\", end=\"\")\n",
        "    print()\n",
        "\n",
        "# ── Kruskal-Wallis ────────────────────────────────────────────────────────\n",
        "print(\"\\n── Tests de Kruskal-Wallis ──\")\n",
        "for label, col in [(\"Score confort\",\"score_confort\"),\n",
        "                    (\"Satisfaction été\",\"sat_ete_num\"),\n",
        "                    (\"Satisfaction hiver\",\"sat_hiver_num\")]:\n",
        "    groups = [df_cl[df_cl[\"cluster\"]==cl][col].dropna().values for cl in range(CHOSEN_K)]\n",
        "    H, p   = kruskal(*groups)\n",
        "    sig    = \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"ns\"))\n",
        "    print(f\"  {label:<25} H={H:.3f}, p={p:.4f} {sig}\")"
      ],
