        "Variance cumulée Dim1+2     = {cum_pct[1]:.1f}%\n",
        "Dimensions retenues (CAH)   = 5\n",
        "\n",
        "SECTION 4 — RÉSULTATS CLUSTERING\n",
        "──────────────────────────────────\n",
        "Méthode                     = CAH Ward (k=3)\n",
        "Silhouette                  = {silhouette_score(X_clust, cah_lab):.4f}\n",
        "Davies-Bouldin              = {davies_bouldin_score(X_clust, cah_lab):.4f}  (↓ meilleur)\n",
        "Calinski-Harabasz           = {calinski_harabasz_score(X_clust, cah_lab):.2f}  (↑ meilleur)\n",
        "Bootstrap Jaccard (moy.)    = C0={np.mean(jac_scores[0]):.2f}, C1={np.mean(jac_scores[1]):.2f}, C2={np.mean(jac_scores[2]):.2f}\n",
        "Puissance statistique       = {power_kruskal:.3f}\n",
        "\n",
        "SECTION 4 — RÉSULTATS PROFILS\n",
        "───────────────────────────────\"\"\")\n",
        "\n",
