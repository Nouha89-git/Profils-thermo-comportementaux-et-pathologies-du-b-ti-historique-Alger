    {
      "cell_type": "code",
      "source": [
        "\n",
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE CRITIQUE 4 — Instabilité clusters : décision k=2 ou k=3      ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from scipy.cluster.hierarchy import linkage, fcluster\n",
        "from sklearn.metrics import silhouette_score, adjusted_rand_score\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"DÉCISION FINALE : k=2 ou k=3 ?\")\n",
        "print(\"Bootstrap Jaccard faibles → analyse comparative\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "Z_link = linkage(X_clust, method=\"ward\")\n",
        "\n",
        "for k in [2, 3]:\n",
        "    cah_k  = fcluster(Z_link, t=k, criterion=\"maxclust\") - 1\n",
        "    km_k   = KMeans(n_clusters=k, random_state=42, n_init=20).fit_predict(X_clust)\n",
        "    sil_k  = silhouette_score(X_clust, cah_k)\n",
        "    ari_k  = adjusted_rand_score(cah_k, km_k)\n",
        "    dist_k = pd.Series(cah_k).value_counts().sort_index().to_dict()\n",
        "    print(f\"\\nk={k} :\")\n",
        "    print(f\"  Distribution   : {dist_k}\")\n",
        "    print(f\"  Silhouette     : {sil_k:.4f}\")\n",
        "    print(f\"  ARI (CAH/KM)   : {ari_k:.4f}\")\n",
        "\n",
        "print(\"\"\"\n",
        "RECOMMANDATION :\n",
        "Si ARI(k=3) < 0.60 ET Jaccard < 0.75 pour tous les clusters,\n",
        "deux options s'offrent à toi :\n",
        "\n",
        "OPTION A — Maintenir k=3 avec limitation explicite :\n",
        "  \"The three-cluster solution was retained on theoretical grounds,\n",
        "   as it corresponds to the three comfort profiles documented in the\n",
        "   adaptive comfort literature (Frontczak & Wargocki, 2011).\n",
        "   However, bootstrap stability analysis (Hennig, 2007) yielded\n",
        "   Jaccard coefficients below the 0.75 threshold (C0=0.52, C1=0.33,\n",
        "   C2=0.44), reflecting the limited sample size and the unequal\n",
        "   cluster sizes (14/14/88). These results should be interpreted\n",
        "   with caution.\"\n",
        "\n",
        "OPTION B — Réduire à k=2 (plus stable) :\n",
        "  Regrouper C0 et C1 en un seul profil \"inconfort/passif\"\n",
        "  face à C2 \"confort relatif\". Plus conservateur mais plus robuste.\n",
        "\n",
        "  → Comparer les profils k=2 vs k=3 et choisir selon\n",
        "    l'interprétabilité théorique dans ton contexte algérois.\n",
        "\"\"\")\n",
        "\n",
        "# ── Figure : comparaison profils k=2 vs k=3 ──────────────────────────────\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "fig.suptitle(\"Comparaison k=2 vs k=3 — Profils de confort\",\n",
        "             fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "df_cl = df.dropna(subset=[\"cluster\"]).copy()\n",
        "df_cl[\"cluster\"] = df_cl[\"cluster\"].astype(int)\n",
        "df_cl[\"cluster_k2\"] = fcluster(Z_link, t=2, criterion=\"maxclust\")[\n",
        "    [list(df.dropna(subset=[\"cluster\"]).index).index(i)\n",
        "     for i in df_cl.index]] - 1\n",
        "\n",
        "for ax, k_col, k_val, title in [\n",
        "    (axes[0], \"cluster\",    3, \"k=3 (CAH Ward)\"),\n",
        "    (axes[1], \"cluster_k2\", 2, \"k=2 (CAH Ward)\"),\n",
        "]:\n",
        "    n_cl = k_val\n",
        "    means_c = [df_cl[df_cl[k_col]==cl][\"score_confort\"].mean() for cl in range(n_cl)]\n",
        "    stds_c  = [df_cl[df_cl[k_col]==cl][\"score_confort\"].std()  for cl in range(n_cl)]\n",
        "    ns_c    = [len(df_cl[df_cl[k_col]==cl]) for cl in range(n_cl)]\n",
        "    colors_k = [\"#185FA5\",\"#D85A30\",\"#3C9E6E\"][:n_cl]\n",
        "    xlabs    = [f\"C{cl}\\n(n={ns_c[cl]})\" for cl in range(n_cl)]\n",
        "\n",
        "    bars = ax.bar(xlabs, means_c, color=colors_k, edgecolor=\"white\", alpha=0.85)\n",
        "    ax.errorbar(xlabs, means_c, yerr=stds_c, fmt=\"none\",\n",
        "                color=\"black\", capsize=5, lw=1.5)\n",
        "    for bar, v, n in zip(bars, means_c, ns_c):\n",
        "        ax.text(bar.get_x()+bar.get_width()/2, v+0.2,\n",
        "                f\"{v:.2f}\", ha=\"center\", fontsize=10)\n",
        "    ax.set_ylim(0, 11)\n",
        "    ax.set_ylabel(\"Score de confort moyen (/10)\")\n",
        "    ax.set_title(title)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/CRITIQUE_k2_vs_k3.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"✓ Figure — k=2 vs k=3 sauvegardée\")"
      ],
