        "    \"Turn on a fan/the AC\":\"beh_fan_ac\",\"Close the shutters\":\"beh_volets_ete\",\n",
        "    \"Open the windows\":\"beh_fen_ouv\",\" Put on lighter clothes\":\"beh_vets_legers\",\n",
        "    \"Turn on or turn up the heating\":\"beh_chauffage\",\n",
        "    \"Put on warmer clothes\":\"beh_vets_chauds\",\"Close the windows\":\"beh_fen_ferm\",\n",
        "})\n",
        "\n",
        "for col in [\"sat_ete\",\"sat_hiver\"]:\n",
        "    df[col+\"_num\"] = df[col].map({\"-2 dissatisfied\":-2,\"-1 Somewhat dissatisfied\":-1,\"0 Acceptable\":0,\"+1 Somewhat satisfied\":1,\"+2 Satisfied\":2})\n",
        "\n",
        "df[\"sensation_num\"] = df[\"sensation\"].map({\"-2 Very cold\":-2,\"-2 Cold\":-2,\"-1 Slightly chilly\":-1,\"-1 Cool\":-1,\"0 Neutral\":0,\"0 Comfortable\":0,\"+1 Slightly hot\":1,\"+2 Hot\":2})\n",
        "\n",
        "for col in [\"infiltr_air\",\"infiltr_eau\",\"humidite\",\"courants_froids\"]:\n",
        "    df[col+\"_bin\"] = (df[col]==\"Yes\").astype(int)\n",
        "\n",
        "df[\"vitrage_simple_bin\"] = df[\"vitrage_type\"].apply(lambda x: 0 if \"Double\" in str(x) and \"Single\" not in str(x) else 1)\n",
        "\n",
        "for col, m in [(\"volet_etat\",{\"Good\":2,\"Medium\":1,\"Degraded\":0}),(\"toiture_etat\",{\"Good\":2,\"Medium\":1,\"Degraded\":0})]:\n",
        "    df[col+\"_num\"] = df[col].map(m)\n",
        "\n",
        "print(f\"✅ df prêt : {df.shape[0]} ménages × {df.shape[1]} variables\")"
