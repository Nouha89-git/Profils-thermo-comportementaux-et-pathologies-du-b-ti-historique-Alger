    {
      "cell_type": "code",
      "source": [
        "fig, axes = plt.subplots(2, 3, figsize=(16, 9))\n",
        "fig.suptitle(\"Figure 1 — Respondent Profile and Housing Characteristics (N=125)\",\n",
        "             fontsize=12, fontweight=\"bold\")\n",
        "\n",
        "vc = df[\"gender\"].value_counts()\n",
        "axes[0,0].pie(vc.values, labels=vc.index, autopct=\"%1.1f%%\",\n",
        "              colors=[\"#1A5FA8\",\"#D04B2F\",\"#2E9E6B\"], startangle=90)\n",
        "axes[0,0].set_title(\"Gender\")\n",
        "\n",
        "vc2 = df[\"occupant_status\"].value_counts()\n",
        "bars = axes[0,1].barh(vc2.index, vc2.values, color=\"#1A5FA8\", edgecolor=\"white\")\n",
        "for bar,v in zip(bars,vc2.values):\n",
        "    axes[0,1].text(v+0.3, bar.get_y()+bar.get_height()/2,\n",
        "                   f\"{v} ({100*v/125:.1f}%)\", va=\"center\", fontsize=8)\n",
        "axes[0,1].set_xlim(0, vc2.max()*1.35); axes[0,1].set_title(\"Occupant Status\")\n",
        "\n",
        "axes[0,2].hist(df[\"age\"].dropna(), bins=10, color=\"#2E9E6B\", edgecolor=\"white\")\n",
        "axes[0,2].axvline(df[\"age\"].mean(), color=\"red\", lw=1.5, linestyle=\"--\",\n",
        "                  label=f\"Mean={df['age'].mean():.1f} yr\")\n",
        "axes[0,2].set_xlabel(\"Age (years)\"); axes[0,2].set_title(\"Age Distribution\")\n",
        "axes[0,2].legend(fontsize=8)\n",
        "\n",
        "axes[1,0].hist(df[\"area\"].dropna(), bins=10, color=\"#D04B2F\", edgecolor=\"white\")\n",
        "axes[1,0].axvline(df[\"area\"].mean(), color=\"blue\", lw=1.5, linestyle=\"--\",\n",
        "                  label=f\"Mean={df['area'].mean():.0f} m2\")\n",
        "axes[1,0].set_xlabel(\"Floor area (m2)\"); axes[1,0].set_title(\"Apartment Size\")\n",
        "axes[1,0].legend(fontsize=8)\n",
        "\n",
        "axes[1,1].hist(df[\"occ_years\"].dropna(), bins=10, color=\"#7B3FA0\", edgecolor=\"white\")\n",
        "axes[1,1].axvline(df[\"occ_years\"].mean(), color=\"red\", lw=1.5, linestyle=\"--\",\n",
        "                  label=f\"Mean={df['occ_years'].mean():.1f} yr\")\n",
        "axes[1,1].set_xlabel(\"Years of occupation\")\n",
        "axes[1,1].set_title(\"Occupation Duration\"); axes[1,1].legend(fontsize=8)\n",
        "\n",
        "vc3 = df[\"floor\"].value_counts().sort_index()\n",
        "axes[1,2].bar(vc3.index.astype(str), vc3.values, color=\"#1A5FA8\", edgecolor=\"white\")\n",
        "axes[1,2].set_xlabel(\"Floor level\"); axes[1,2].set_title(\"Floor Distribution\")\n",
        "\n",
        "save(\"fig01_respondent_profile\")"
      ],
      "metadata": {
        "colab": {
