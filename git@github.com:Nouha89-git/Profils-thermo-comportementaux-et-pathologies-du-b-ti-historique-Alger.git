        "axes[0,1].axhline(0, color=\"black\", lw=0.8, linestyle=\"--\")\n",
        "axes[0,1].set_xticks(x); axes[0,1].set_xticklabels(cl_labels, fontsize=8)\n",
        "axes[0,1].set_ylabel(\"Satisfaction moyenne (−2 → +2)\")\n",
        "axes[0,1].set_title(\"B) Satisfaction saisonnière\")\n",
        "axes[0,1].legend(fontsize=9)\n",
        "\n",
        "# C) Pathologies enveloppe\n",
        "path_cols = [\"infiltr_air_bin\",\"infiltr_eau_bin\",\"humidite_bin\",\"courants_froids_bin\"]\n",
        "path_lbl  = [\"Infiltr.\\nair\",\"Infiltr.\\neau\",\"Humidité\",\"Courants\\nfroids\"]\n",
        "x2 = np.arange(len(path_cols))\n",
        "for i, col_c in enumerate(colors4):\n",
        "    vals = [df_cl[df_cl[\"cluster\"]==i][pc].mean()*100 for pc in path_cols]\n",
