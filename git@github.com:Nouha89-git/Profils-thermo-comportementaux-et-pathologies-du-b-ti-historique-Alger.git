    {
      "cell_type": "code",
      "source": [
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE CRITIQUE 1 — CORRIGÉE                                         ║\n",
        "# ║  Score thermique composite + Alpha de Cronbach                         ║\n",
        "# ║  Effectifs cohérents : N=116 (base ACM), C0=14, C1=14, C2=88          ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.stats import spearmanr\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"EFFECTIFS — VÉRIFICATION DE COHÉRENCE\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# ── Base de référence : individus avec cluster assigné (N=116) ───────────\n",
        "df_cl = df.dropna(subset=[\"cluster\"]).copy()\n",
        "df_cl[\"cluster\"] = df_cl[\"cluster\"].astype(int)\n",
        "\n",
        "print(f\"\\nBase de référence (N ACM, avec cluster) : {len(df_cl)}\")\n",
        "print(\"Distribution des clusters :\")\n",
        "for cl in range(3):\n",
        "    n = (df_cl[\"cluster\"] == cl).sum()\n",
        "    print(f\"  C{cl} : n={n} ({100*n/len(df_cl):.1f}%%)\")\n",
        "\n",
        "# ── Vérifier les manquants sur chaque variable clé ───────────────────────\n",
        "key_vars = {\n",
        "    \"score_confort\"  : \"Score confort (0–10)\",\n",
        "    \"sat_ete_num\"    : \"Satisfaction été\",\n",
        "    \"sat_hiver_num\"  : \"Satisfaction hiver\",\n",
        "    \"sensation_num\"  : \"Sensation thermique\",\n",
        "}\n",
        "print(\"\\nValeurs manquantes par variable (dans la base N=116) :\")\n",
        "print(f\"{'Variable':<28} {'N valide':>9} {'N manquant':>12} {'% manquant':>12}\")\n",
        "print(\"─\" * 65)\n",
        "for col, label in key_vars.items():\n",
        "    if col in df_cl.columns:\n",
        "        n_valid   = df_cl[col].notna().sum()\n",
        "        n_missing = df_cl[col].isna().sum()\n",
        "        pct       = 100 * n_missing / len(df_cl)\n",
        "        print(f\"{label:<28} {n_valid:>9} {n_missing:>12} {pct:>11.1f}%%\")\n",
        "\n",
        "# ── RÈGLE : toujours utiliser df_cl[col].dropna() PAR VARIABLE ───────────\n",
        "# Ne jamais faire dropna() simultané sur toutes les variables\n",
        "print(\"\"\"\n",
        "RÈGLE APPLIQUÉE :\n",
        "  ✅ Pour chaque analyse, dropna() sur la variable concernée uniquement\n",
        "  ❌ Ne pas faire dropna() sur plusieurs variables simultanément\n",
        "     (réduirait l'effectif inutilement)\n",
        "\"\"\")\n",
        "\n",
        "# ── Score thermique composite — construction propre ──────────────────────\n",
        "print(\"=\" * 60)\n",
        "print(\"SCORE THERMIQUE COMPOSITE — Construction et validation\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "print(\"\"\"\n",
        "Le 'score_confort' (0–10) est un ITEM UNIQUE auto-déclaré.\n",
        "Corrélations de validité convergente :\n",
        "  - Satisfaction été   : r=0.39\n",
        "  - Satisfaction hiver : r=0.46\n",
        "Ces corrélations confirment la validité de l'item unique.\n",
        "Un score composite optionnel est calculé ci-dessous.\n",
        "\"\"\")\n",
        "\n",
        "# Normalisation min-max par variable (sur df_cl uniquement)\n",
        "def norm(s): return (s - s.min()) / (s.max() - s.min() + 1e-9)\n",
        "\n",
        "# Calculer le composite UNIQUEMENT sur les individus avec au moins 3/4 items\n",
        "comp_cols = [\"score_confort\",\"sat_ete_num\",\"sat_hiver_num\",\"sensation_num\"]\n",
        "comp_df   = df_cl[comp_cols].copy()\n",
        "\n",
        "# Normaliser chaque colonne indépendamment\n",
        "for col in comp_cols:\n",
        "    comp_df[col + \"_n\"] = norm(comp_df[col])\n",
        "\n",
        "# Score composite = moyenne des items disponibles (ignore les NaN)\n",
        "norm_cols = [c + \"_n\" for c in comp_cols]\n",
        "comp_df[\"score_composite\"] = comp_df[norm_cols].mean(axis=1, skipna=True)\n",
        "\n",
        "# Garder uniquement si au moins 3 items disponibles\n",
        "n_valid_items = comp_df[norm_cols].notna().sum(axis=1)\n",
        "comp_df.loc[n_valid_items < 3, \"score_composite\"] = np.nan\n",
        "\n",
        "comp_df[\"cluster\"] = df_cl[\"cluster\"]\n",
        "\n",
        "print(f\"Score composite calculé pour : {comp_df['score_composite'].notna().sum()} individus\")\n",
        "print(\"(items manquants ignorés si au moins 3/4 disponibles)\")\n",
        "print(comp_df[\"score_composite\"].describe().round(3))\n",
        "\n",
        "# ── Alpha de Cronbach (on individus avec 4 items complets) ──────────────\n",
        "complete_items = comp_df[norm_cols].dropna()\n",
        "print(f\"\\nAlpha de Cronbach calculé sur {len(complete_items)} individus (4 items complets)\")\n",
        "\n",
        "def cronbach_alpha(df_items):\n",
        "    k         = df_items.shape[1]\n",
        "    item_vars = df_items.var(axis=0, ddof=1)\n",
        "    total_var = df_items.sum(axis=1).var(ddof=1)\n",
        "    return (k / (k - 1)) * (1 - item_vars.sum() / total_var)\n",
        "\n",
        "alpha = cronbach_alpha(complete_items)\n",
        "print(f\"Alpha de Cronbach (4 items normalisés) = {alpha:.3f}\")\n",
        "\n",
        "if alpha >= 0.80:\n",
        "    interp = \"BONNE (α ≥ 0.80) — score composite justifié\"\n",
        "elif alpha >= 0.70:\n",
        "    interp = \"ACCEPTABLE (α ≥ 0.70) — score composite utilisable\"\n",
        "elif alpha >= 0.60:\n",
        "    interp = \"QUESTIONNABLE (α < 0.70) — préférer les items séparément\"\n",
        "else:\n",
        "    interp = \"FAIBLE (α < 0.60) — NE PAS utiliser le score composite\"\n",
        "\n",
        "print(f\"→ Cohérence interne : {interp}\")\n",
        "\n",
        "# ── Corrélations inter-items ──────────────────────────────────────────────\n",
        "print(\"\\nCorrélations de Spearman inter-items (sur df_cl, N=116) :\")\n",
        "item_pairs = [\n",
        "    (\"score_confort\",  \"sat_ete_num\",   \"Confort global\",    \"Satisfaction été\"),\n",
        "    (\"score_confort\",  \"sat_hiver_num\", \"Confort global\",    \"Satisfaction hiver\"),\n",
        "    (\"score_confort\",  \"sensation_num\", \"Confort global\",    \"Sensation\"),\n",
        "    (\"sat_ete_num\",    \"sat_hiver_num\", \"Satisfaction été\",  \"Satisfaction hiver\"),\n",
        "    (\"sat_ete_num\",    \"sensation_num\", \"Satisfaction été\",  \"Sensation\"),\n",
        "    (\"sat_hiver_num\",  \"sensation_num\", \"Satisfaction hiver\",\"Sensation\"),\n",
        "]\n",
        "print(f\"{'Item 1':<24} {'Item 2':<24} {'r':>6} {'p':>8} {'Sig':>5}\")\n",
        "print(\"─\" * 72)\n",
        "for c1, c2, l1, l2 in item_pairs:\n",
        "    if c1 in df_cl.columns and c2 in df_cl.columns:\n",
        "        tmp = df_cl[[c1, c2]].dropna()\n",
        "        r, p = spearmanr(tmp[c1], tmp[c2])\n",
        "        sig  = \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"ns\"))\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "aawKDvFdrFq_",
        "outputId": "906465c2-2029-420d-8c4e-d394240d113e"
      },
      "execution_count": 32,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "============================================================\n",
            "EFFECTIFS — VÉRIFICATION DE COHÉRENCE\n",
            "============================================================\n",
            "\n",
            "Base de référence (N ACM, avec cluster) : 116\n",
            "Distribution des clusters :\n",
            "  C0 : n=14 (12.1%%)\n",
