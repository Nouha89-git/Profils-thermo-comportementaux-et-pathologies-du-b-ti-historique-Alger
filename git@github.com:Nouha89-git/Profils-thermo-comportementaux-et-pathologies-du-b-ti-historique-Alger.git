    {
      "cell_type": "code",
      "source": [
        "def cronbach_alpha(data):\n",
        "    k = data.shape[1]\n",
        "    return (k/(k-1))*(1 - data.var(ddof=1).sum()/data.sum(axis=1).var(ddof=1))\n",
        "\n",
        "norm = lambda s: (s-s.min())/(s.max()-s.min()+1e-9)\n",
        "items = df[[\"comfort_score\",\"sat_summer_n\",\"sat_winter_n\",\"sensation_n\"]].dropna()\n",
        "alpha = cronbach_alpha(items.apply(norm))\n",
        "print(f\"comfort_score = SINGLE self-reported item (0-10), NOT a composite\")\n",
        "print(f\"Cronbach alpha (4-item composite) = {alpha:.3f}\")\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "fig.suptitle(\"Figure 3 — Perceived Thermal Comfort and Adaptive Behaviors (N=125)\",\n",
        "             fontsize=12, fontweight=\"bold\")\n",
        "\n",
        "axes[0,0].hist(df[\"comfort_score\"].dropna(), bins=10, color=\"#7B3FA0\", edgecolor=\"white\")\n",
        "axes[0,0].axvline(df[\"comfort_score\"].mean(), color=\"red\", lw=1.5, linestyle=\"--\",\n",
        "                  label=f\"Mean={df['comfort_score'].mean():.2f}\")\n",
        "axes[0,0].set_xlabel(\"Thermal comfort score (0-10) [single self-reported item]\")\n",
        "axes[0,0].set_title(f\"A) Overall Comfort Score\\n(4-item Cronbach alpha={alpha:.2f})\")\n",
        "axes[0,0].legend(fontsize=8)\n",
        "\n",
        "order = [\"-2 dissatisfied\",\"-1 Somewhat dissatisfied\",\"0 Acceptable\",\n",
        "         \"+1 Somewhat satisfied\",\"+2 Satisfied\"]\n",
        "x = np.arange(5); w = 0.35\n",
        "sc = [df[\"sat_summer\"].value_counts().get(o,0) for o in order]\n",
        "wc = [df[\"sat_winter\"].value_counts().get(o,0) for o in order]\n",
        "axes[0,1].bar(x-w/2, sc, w, label=\"Summer\", color=\"#D04B2F\", edgecolor=\"white\")\n",
        "axes[0,1].bar(x+w/2, wc, w, label=\"Winter\", color=\"#1A5FA8\", edgecolor=\"white\")\n",
        "axes[0,1].set_xticks(x); axes[0,1].set_xticklabels([\"-2\",\"-1\",\"0\",\"+1\",\"+2\"])\n",
        "u, p_mwu = mannwhitneyu(df[\"sat_summer_n\"].dropna(),\n",
        "                          df[\"sat_winter_n\"].dropna(), alternative=\"two-sided\")\n",
        "axes[0,1].set_title(f\"B) Satisfaction Summer vs Winter\\n(Mann-Whitney U={u:.0f}, p={p_mwu:.3f})\")\n",
        "axes[0,1].legend()\n",
        "\n",
        "beh_s = {\"Fan/AC\":\"beh_fan_ac\",\"Close shutters\":\"beh_close_shutters\",\n",
        "          \"Open windows\":\"beh_open_windows\",\"Light clothes\":\"beh_light_clothes\"}\n",
        "beh_s = {k:v for k,v in beh_s.items() if v in df.columns}\n",
        "pcts_s = [df[col].mean()*100 for col in beh_s.values()]\n",
        "bars3 = axes[1,0].barh(list(beh_s.keys()), pcts_s, color=\"#D04B2F\", edgecolor=\"white\")\n",
        "for bar,p in zip(bars3,pcts_s):\n",
        "    axes[1,0].text(p+0.5, bar.get_y()+bar.get_height()/2,\n",
        "                   f\"{p:.1f}%\", va=\"center\", fontsize=9)\n",
        "axes[1,0].set_xlim(0,110); axes[1,0].set_title(\"C) Adaptive Strategies - Summer\")\n",
        "\n",
        "beh_w = {\"Turn on heating\":\"beh_heating\",\"Warmer clothes\":\"beh_warm_clothes\",\n",
        "          \"Close windows\":\"beh_close_windows\"}\n",
        "pcts_w = [df[col].mean()*100 for col in beh_w.values()]\n",
        "bars4 = axes[1,1].barh(list(beh_w.keys()), pcts_w, color=\"#1A5FA8\", edgecolor=\"white\")\n",
        "for bar,p in zip(bars4,pcts_w):\n",
        "    axes[1,1].text(p+0.5, bar.get_y()+bar.get_height()/2,\n",
        "                   f\"{p:.1f}%\", va=\"center\", fontsize=9)\n",
        "axes[1,1].set_xlim(0,110); axes[1,1].set_title(\"D) Adaptive Strategies - Winter\")\n",
        "\n",
        "save(\"fig03_thermal_comfort_behaviors\")"
      ],
