        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 10 — Résumé complet + exports                                 ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "print(\"=\" * 60)\n",
        "print(\"RÉSUMÉ STATISTIQUE FINAL — ARTICLE Q1\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "print(f\"\"\"\n",
        "SECTION 3 — MÉTHODES\n",
        "  N total              = 125 ménages\n",
        "  N retenu (ACM)       = {N_acm} (base de référence cohérente)\n",
        "  Q variables ACM      = {Q}  |  K modalités = {K}\n",
        "  Inertie totale ACM   = {inertia_T:.4f}\n",
        "  Dim 1 : λ={eig[0]:.4f}, {exp_pct[0]:.1f}%\n",
        "  Dim 2 : λ={eig[1]:.4f}, {exp_pct[1]:.1f}%\n",
        "  Variance Dim1+2      = {cum_pct[1]:.1f}%\n",
        "  Dimensions → CAH     = 5\n",
        "\n",
        "SECTION 4 — CLUSTERING\n",
        "  Méthode              = CAH Ward, k=4 (retenu)\n",
        "  Silhouette           = {silhouette_score(X_clust, cah_lab):.4f}\n",
        "  Davies-Bouldin       = {davies_bouldin_score(X_clust, cah_lab):.4f}\n",
        "  Calinski-Harabasz    = {calinski_harabasz_score(X_clust, cah_lab):.2f}\n",
        "  ARI (CAH vs K-Means) = {adjusted_rand_score(cah_lab, km_lab):.4f}\n",
        "\"\"\")\n",
        "\n",
        "print(\"  Distribution des clusters :\")\n",
        "for cl in range(CHOSEN_K):\n",
        "    n = (df_cl[\"cluster\"]==cl).sum()\n",
        "    c = df_cl[df_cl[\"cluster\"]==cl][\"score_confort\"].mean()\n",
        "    print(f\"  {CLUSTER_NAMES[cl]:<30} n={n:3d} ({100*n/N_acm:.1f}%)  confort moy={c:.2f}\")\n",
        "\n",
        "print(f\"\"\"\n",
        "SECTION 4 — TESTS STATISTIQUES\n",
        "  LDA Accuracy CV-10   = {cv_acc.mean():.3f} ± {cv_acc.std():.3f}\n",
        "  LDA Variance LD1     = {lda.explained_variance_ratio_[0]*100:.1f}%\n",
        "\n",
        "LIMITE À DÉCLARER\n",
