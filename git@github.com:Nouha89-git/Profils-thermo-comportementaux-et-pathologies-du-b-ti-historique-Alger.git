        "axes[0,0].set_title(\"Type de vitrage\")\n",
        "\n",
        "# 2. État des volets\n",
        "vc2 = df_raw[\"Shutter state\"].value_counts()\n",
        "colors_etat = {\"Good\":\"#3C9E6E\", \"Medium\":\"#BA7517\", \"Degraded\":\"#D85A30\"}\n",
        "axes[0,1].bar(vc2.index, vc2.values,\n",
        "              color=[colors_etat.get(k,\"grey\") for k in vc2.index],\n",
        "              edgecolor=\"white\")\n",
        "for i, (k, v) in enumerate(vc2.items()):\n",
        "    axes[0,1].text(i, v+0.5, f\"{100*v/len(df_raw):.1f}%\", ha=\"center\", fontsize=9)\n",
        "axes[0,1].set_title(\"État des volets\")\n",
        "\n",
        "# 3. État de la toiture\n",
        "vc3 = df_raw[\"Roof waterproofing status\"].value_counts()\n",
        "axes[0,2].bar(vc3.index, vc3.values,\n",
        "              color=[colors_etat.get(k,\"grey\") for k in vc3.index],\n",
        "              edgecolor=\"white\")\n",
        "for i, (k, v) in enumerate(vc3.items()):\n",
        "    axes[0,2].text(i, v+0.5, f\"{100*v/len(df_raw):.1f}%\", ha=\"center\", fontsize=9)\n",
        "axes[0,2].set_title(\"État de la toiture\")\n",
        "\n",
        "# 4. Prévalence des pathologies\n",
        "path_labels = [\"Infiltration\\nair\", \"Infiltration\\neau\",\n",
        "               \"Humidité/\\nmoisissures\", \"Courants\\nfroids\"]\n",
        "path_cols   = [\"infiltr_air_bin\",\"infiltr_eau_bin\",\"humidite_bin\",\"courants_froids_bin\"]\n",
        "pcts = [df[c].mean()*100 for c in path_cols]\n",
        "bars = axes[1,0].bar(path_labels, pcts,\n",
