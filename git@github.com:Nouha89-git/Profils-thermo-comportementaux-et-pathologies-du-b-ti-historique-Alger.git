      "cell_type": "code",
      "source": [
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 8 — Régression logistique ordinale                            ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "\"\"\"\n",
        "Utilisée comme outil INFÉRENTIEL (identifier les OR significatifs),\n",
        "pas prédictif (pseudo-R² attendu faible pour variables binaires, N=116).\n",
        "\"\"\"\n",
        "\n",
        "print(\"=\" * 55)\n",
        "print(\"RÉGRESSION LOGISTIQUE ORDINALE — Satisfaction thermique\")\n",
        "print(\"=\" * 55)\n",
        "\n",
        "pred_cols = [\"infiltr_air_bin\",\"courants_froids_bin\",\"vitrage_simple_bin\",\n",
        "             \"volet_etat_num\",\"toiture_etat_num\",\"beh_fan_ac\",\n",
        "             \"beh_chauffage\",\"superficie\"]\n",
        "pred_lbl  = {\n",
        "    \"infiltr_air_bin\"    : \"Infiltration air\",\n",
        "    \"courants_froids_bin\": \"Courants froids\",\n",
        "    \"vitrage_simple_bin\" : \"Vitrage simple\",\n",
        "    \"volet_etat_num\"     : \"État volets\",\n",
        "    \"toiture_etat_num\"   : \"État toiture\",\n",
        "    \"beh_fan_ac\"         : \"Fan/clim (été)\",\n",
        "    \"beh_chauffage\"      : \"Chauffage (hiver)\",\n",
        "    \"superficie\"         : \"Superficie\",\n",
        "}\n",
        "\n",
        "# Base : df_cl (N=116, cohérent)\n",
        "results_logit = {}\n",
        "for season, dep_col in [(\"Été\",\"sat_ete_num\"), (\"Hiver\",\"sat_hiver_num\")]:\n",
        "    reg = df_cl[pred_cols + [dep_col]].dropna().copy()\n",
        "    reg[dep_col+\"_cat\"] = pd.Categorical(\n",
        "        reg[dep_col].astype(int),\n",
        "        categories=sorted(reg[dep_col].dropna().unique().astype(int)),\n",
        "        ordered=True\n",
        "    )\n",
        "    print(f\"\\n── Satisfaction {season} (N={len(reg)}) ──\")\n",
        "    try:\n",
        "        model  = OrderedModel(reg[dep_col+\"_cat\"],\n",
        "                              reg[pred_cols].astype(float),\n",
        "                              distr=\"logit\")\n",
        "        result = model.fit(method=\"bfgs\", disp=False)\n",
        "        pseudo_r2 = 1 - result.llf / result.llnull\n",
        "        print(f\"Pseudo-R² McFadden = {pseudo_r2:.3f}\")\n",
        "        results_logit[season] = result\n",
        "\n",
        "        # Tableau OR\n",
        "        params = result.params[pred_cols]\n",
        "        pvals  = result.pvalues[pred_cols]\n",
        "        conf   = result.conf_int().loc[pred_cols]\n",
        "        print(f\"\\n{'Prédicteur':<25} {'OR':>6} {'IC95% Lo':>9} {'IC95% Hi':>9} {'p':>8} {'Sig':>4}\")\n",
        "        print(\"─\"*58)\n",
        "        for var in pred_cols:\n",
        "            or_v = np.exp(params[var])\n",
        "            lo   = np.exp(conf.loc[var, 0])\n",
        "            hi   = np.exp(conf.loc[var, 1])\n",
        "            p    = pvals[var]\n",
        "            sig  = \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"ns\"))\n",
        "            flag = \" ←\" if p<0.05 else \"\"\n",
        "            lbl  = pred_lbl.get(var, var)\n",
        "            print(f\"{lbl:<25} {or_v:>6.2f} {lo:>9.2f} {hi:>9.2f} {p:>8.4f} {sig:>4}{flag}\")\n",
        "    except Exception as e:\n",
        "        print(f\"  Erreur : {e}\")\n",
        "\n",
        "# ── Figure 6 : OR plot ────────────────────────────────────────────────────\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
        "fig.suptitle(\"Figure 6 — Odds Ratios (Régression Logistique Ordinale)\\n\"\n",
        "             \"Prédicteurs de la satisfaction thermique saisonnière\",\n",
        "             fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "for ax, season, color in [(axes[0],\"Été\",\"#D85A30\"),(axes[1],\"Hiver\",\"#185FA5\")]:\n",
        "    if season not in results_logit:\n",
        "        continue\n",
        "    result = results_logit[season]\n",
        "    params = result.params[pred_cols]\n",
        "    pvals  = result.pvalues[pred_cols]\n",
        "    conf   = result.conf_int().loc[pred_cols]\n",
        "\n",
        "    or_vals = np.exp(params.values)\n",
        "    lo_vals = np.exp(conf.iloc[:,0].values)\n",
        "    hi_vals = np.exp(conf.iloc[:,1].values)\n",
        "    labels  = [pred_lbl.get(v,v) for v in pred_cols]\n",
        "    pv      = pvals.values\n",
        "\n",
        "    # Trier par OR\n",
        "    idx    = np.argsort(or_vals)\n",
        "    or_s   = or_vals[idx]; lo_s = lo_vals[idx]; hi_s = hi_vals[idx]\n",
        "    lbl_s  = [labels[i] for i in idx]; pv_s = pv[idx]\n",
        "\n",
        "    bar_colors = [color if p<0.05 else \"#cccccc\" for p in pv_s]\n",
        "    ax.barh(range(len(lbl_s)), or_s-1, left=1,\n",
        "            color=bar_colors, edgecolor=\"white\", alpha=0.85, height=0.6)\n",
        "    ax.errorbar(or_s, range(len(lbl_s)),\n",
        "                xerr=[or_s-lo_s, hi_s-or_s],\n",
        "                fmt=\"none\", color=\"black\", capsize=4, lw=1.2)\n",
        "    ax.axvline(1, color=\"black\", lw=1.2, linestyle=\"--\")\n",
        "    ax.set_yticks(range(len(lbl_s)))\n",
        "    ax.set_yticklabels(lbl_s, fontsize=8)\n",
        "    ax.set_xlabel(\"Odds Ratio\")\n",
        "    ax.set_title(f\"Satisfaction {season}\\n(gris = p≥0.05)\")\n",
        "\n",
        "    for i, (ov, p) in enumerate(zip(or_s, pv_s)):\n",
        "        sig = \"***\" if p<0.001 else (\"**\" if p<0.01 else (\"*\" if p<0.05 else \"\"))\n",
        "        if sig:\n",
        "            ax.text(max(hi_s)+0.05, i, sig, va=\"center\", fontsize=9)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/fig6_odds_ratios.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"✓ Figure 6 — Odds Ratios\")"
      ],
