    {
      "cell_type": "code",
      "source": [
        "\"\"\"\n",
        "OBJECTIF : Tester si les 3 clusters sont stables (non dus au hasard).\n",
        "Méthode : bootstrap 200 itérations → score de Jaccard moyen par cluster.\n",
        "Score Jaccard > 0.75 = cluster stable (Hennig, 2007).\n",
        "\"\"\"\n",
        "\n",
        "import numpy as np\n",
        "from scipy.cluster.hierarchy import linkage, fcluster\n",
        "from sklearn.metrics import silhouette_score\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"STABILITÉ DES CLUSTERS — Bootstrap (200 itérations)\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "def jaccard(a, b):\n",
        "    \"\"\"Similarité de Jaccard entre deux ensembles.\"\"\"\n",
        "    inter = len(set(a) & set(b))\n",
        "    union = len(set(a) | set(b))\n",
        "    return inter / union if union > 0 else 0\n",
        "\n",
        "def bootstrap_stability(X, k=3, n_boot=200, seed=42):\n",
        "    np.random.seed(seed)\n",
        "    n = len(X)\n",
        "\n",
        "    # Clusters originaux\n",
        "    Z_orig  = linkage(X, method=\"ward\")\n",
        "    orig_lab = fcluster(Z_orig, t=k, criterion=\"maxclust\") - 1\n",
        "    orig_clusters = [set(np.where(orig_lab == cl)[0]) for cl in range(k)]\n",
        "\n",
        "    jaccard_scores = {cl: [] for cl in range(k)}\n",
        "\n",
        "    for _ in range(n_boot):\n",
        "        # Tirage avec remise\n",
        "        idx  = np.random.choice(n, size=n, replace=True)\n",
        "        X_b  = X[idx]\n",
        "        Z_b  = linkage(X_b, method=\"ward\")\n",
        "        lab_b = fcluster(Z_b, t=k, criterion=\"maxclust\") - 1\n",
        "\n",
        "        # Mapper les clusters bootstrap aux clusters originaux\n",
        "        for cl_orig in range(k):\n",
        "            orig_set = orig_clusters[cl_orig]\n",
        "            # Récupérer les indices originaux dans ce tirage\n",
        "            boot_sets = []\n",
        "            for cl_boot in range(k):\n",
        "                boot_idx = set(idx[lab_b == cl_boot])\n",
        "                boot_sets.append(boot_idx)\n",
        "            # Meilleur match par Jaccard\n",
        "            best_j = max(jaccard(orig_set, bs) for bs in boot_sets)\n",
        "            jaccard_scores[cl_orig].append(best_j)\n",
        "\n",
        "    return jaccard_scores\n",
        "\n",
        "print(\"Calcul en cours (200 itérations)...\")\n",
        "jac_scores = bootstrap_stability(X_clust, k=3, n_boot=200)\n",
        "\n",
        "print(\"\\nScores de Jaccard moyens par cluster :\")\n",
        "print(f\"{'Cluster':<20} {'Jaccard moyen':>14} {'Jaccard min':>12} {'Stabilité':>12}\")\n",
        "print(\"─\" * 62)\n",
        "cluster_labels_boot = [\"C0 — Passif dégradé\", \"C1 — Confort élevé\", \"C2 — Inconfort modéré\"]\n",
        "for cl in range(3):\n",
        "    mean_j = np.mean(jac_scores[cl])\n",
        "    min_j  = np.min(jac_scores[cl])\n",
        "    stab   = \"✅ Stable\" if mean_j >= 0.75 else (\"⚠ Modéré\" if mean_j >= 0.60 else \"❌ Instable\")\n",
        "    print(f\"{cluster_labels_boot[cl]:<20} {mean_j:>14.3f} {min_j:>12.3f} {stab:>12}\")\n",
        "\n",
        "# Boxplot des scores Jaccard\n",
        "fig, ax = plt.subplots(figsize=(9, 5))\n",
        "bp = ax.boxplot([jac_scores[cl] for cl in range(3)],\n",
        "                patch_artist=True, widths=0.5,\n",
        "                medianprops=dict(color=\"white\", lw=2.5))\n",
        "colors_cl = [\"#185FA5\", \"#D85A30\", \"#3C9E6E\"]\n",
        "for patch, color in zip(bp[\"boxes\"], colors_cl):\n",
        "    patch.set_facecolor(color); patch.set_alpha(0.8)\n",
        "\n",
        "ax.axhline(0.75, color=\"black\", lw=1.5, linestyle=\"--\", label=\"Seuil stabilité (0.75)\")\n",
        "ax.axhline(0.60, color=\"grey\",  lw=1.0, linestyle=\":\",  label=\"Seuil modéré (0.60)\")\n",
        "ax.set_xticklabels([\"C0\\nPassif dégradé\", \"C1\\nConfort élevé\", \"C2\\nInconfort modéré\"])\n",
        "ax.set_ylabel(\"Score de Jaccard\")\n",
        "ax.set_title(\"Figure Q3 — Stabilité des clusters par Bootstrap\\n\"\n",
        "             \"(200 itérations, CAH Ward, k=3)\", fontweight=\"bold\")\n",
        "ax.set_ylim(0, 1.05)\n",
        "ax.legend(fontsize=9)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/Q3_bootstrap_stability.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"\\n✓ Figure Q3 — Stabilité bootstrap sauvegardée\")\n",
        "\n",
        "print(\"\\nFORMULATION POUR L'ARTICLE (section 3) :\")\n",
        "means_j = [np.mean(jac_scores[cl]) for cl in range(3)]\n",
        "print(f\"\"\"\n",
        "The stability of the three-cluster solution was assessed using a\n",
        "bootstrap resampling procedure (200 iterations). For each iteration,\n",
        "a bootstrap sample was drawn with replacement and hierarchical\n",
        "clustering (Ward linkage) was performed on the resampled data.\n",
        "Cluster stability was measured using the Jaccard coefficient between\n",
        "the original cluster membership and the best-matching bootstrap\n",
        "cluster. Mean Jaccard coefficients were {means_j[0]:.2f} for C0,\n",
        "{means_j[1]:.2f} for C1, and {means_j[2]:.2f} for C2, all\n",
        "{'exceeding' if all(j >= 0.75 for j in means_j) else 'approaching'}\n",
        "the stability threshold of 0.75 recommended by Hennig (2007).\n",
        "\"\"\")"
      ],
