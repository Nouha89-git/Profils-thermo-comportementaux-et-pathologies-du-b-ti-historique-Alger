        "axes[1,0].set_xticks(x2 + 0.3)\n",
        "axes[1,0].set_xticklabels(path_lbl, fontsize=8)\n",
        "axes[1,0].set_ylabel(\"% ménages\")\n",
        "axes[1,0].set_ylim(0, 115)\n",
        "axes[1,0].set_title(\"C) Pathologies de l'enveloppe\")\n",
