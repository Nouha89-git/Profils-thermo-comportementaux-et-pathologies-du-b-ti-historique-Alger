    {
      "cell_type": "code",
      "source": [
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE CRITIQUE 3 — Cramér's V avec seuils de Cohen                 ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.cluster import KMeans\n",
        "from sklearn.metrics import (adjusted_rand_score, silhouette_score,\n",
        "                              davies_bouldin_score, calinski_harabasz_score)\n",
        "from scipy.cluster.hierarchy import linkage, fcluster\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"ADJUSTED RAND INDEX (ARI) — Concordance CAH vs K-Means\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "print(\"\"\"\n",
        "QU'EST-CE QUE L'ARI ?\n",
        "L'ARI mesure la concordance entre deux partitions (CAH et K-Means).\n",
        "ARI = 1.0 → partitions identiques\n",
        "ARI = 0.0 → concordance au niveau du hasard\n",
        "ARI < 0   → moins bon que le hasard\n",
        "\n",
        "Un ARI > 0.60 entre CAH et K-Means indique que les deux méthodes\n",
        "trouvent des structures similaires → clusters robustes.\n",
        "\"\"\")\n",
        "\n",
        "# Recalculer si pas disponible\n",
        "Z_link  = linkage(X_clust, method=\"ward\")\n",
        "cah_lab = fcluster(Z_link, t=3, criterion=\"maxclust\") - 1\n",
        "km_lab  = KMeans(n_clusters=3, random_state=42, n_init=20).fit_predict(X_clust)\n",
        "\n",
        "ari = adjusted_rand_score(cah_lab, km_lab)\n",
        "print(f\"ARI (CAH Ward vs K-Means, k=3) = {ari:.4f}\")\n",
        "if ari >= 0.80:\n",
        "    print(\"  → ✅ Concordance FORTE — clusters très robustes\")\n",
        "elif ari >= 0.60:\n",
        "    print(\"  → ✅ Concordance BONNE — clusters robustes\")\n",
        "elif ari >= 0.40:\n",
        "    print(\"  → ⚠ Concordance MODÉRÉE — clusters partiellement stables\")\n",
        "else:\n",
        "    print(\"  → ❌ Concordance FAIBLE — résultats à interpréter avec prudence\")\n",
        "\n",
        "# ARI pour k=2 à 6\n",
        "print(\"\\nARI par k :\")\n",
        "print(f\"{'k':>3} | {'ARI':>8} | {'Silhouette':>12} | {'Calinski-H':>12}\")\n",
        "print(\"─\"*42)\n",
        "for k in range(2, 7):\n",
        "    cah_k = fcluster(Z_link, t=k, criterion=\"maxclust\") - 1\n",
        "    km_k  = KMeans(n_clusters=k, random_state=42, n_init=20).fit_predict(X_clust)\n",
        "    ari_k = adjusted_rand_score(cah_k, km_k)\n",
        "    sil_k = silhouette_score(X_clust, cah_k)\n",
        "    ch_k  = calinski_harabasz_score(X_clust, cah_k)\n",
        "    flag  = \" ← retenu\" if k==3 else \"\"\n",
        "    print(f\"  {k} | {ari_k:>8.4f} | {sil_k:>12.4f} | {ch_k:>12.2f}{flag}\")\n",
        "\n",
        "# Tableau croisé CAH vs K-Means (k=3)\n",
        "print(\"\\nTableau de concordance CAH vs K-Means (k=3) :\")\n",
        "print(pd.crosstab(cah_lab, km_lab, rownames=[\"CAH\"], colnames=[\"K-Means\"]))\n",
        "\n",
        "# ── Figure ARI + indices ──────────────────────────────────────────────────\n",
        "ks = list(range(2, 7))\n",
        "aris, sils, chs, dbs = [], [], [], []\n",
        "for k in ks:\n",
        "    cah_k = fcluster(Z_link, t=k, criterion=\"maxclust\") - 1\n",
        "    km_k  = KMeans(n_clusters=k, random_state=42, n_init=20).fit_predict(X_clust)\n",
        "    aris.append(adjusted_rand_score(cah_k, km_k))\n",
        "    sils.append(silhouette_score(X_clust, cah_k))\n",
        "    chs.append(calinski_harabasz_score(X_clust, cah_k))\n",
        "    dbs.append(davies_bouldin_score(X_clust, cah_k))\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(12, 8))\n",
        "fig.suptitle(\"Indices de validation des clusters — Vue complète\",\n",
        "             fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "for ax, vals, title, color, note in [\n",
        "    (axes[0,0], aris, \"ARI — Concordance CAH vs K-Means\\n(↑ meilleur, > 0.60 = robuste)\",\n",
        "     \"#534AB7\", True),\n",
        "    (axes[0,1], sils, \"Silhouette\\n(↑ meilleur, > 0.50 = fort)\",\n",
        "     \"#185FA5\", True),\n",
        "    (axes[1,0], chs,  \"Calinski-Harabasz\\n(↑ meilleur)\",\n",
        "     \"#3C9E6E\", False),\n",
        "    (axes[1,1], dbs,  \"Davies-Bouldin\\n(↓ meilleur, < 1.0 = bon)\",\n",
        "     \"#D85A30\", False),\n",
        "]:\n",
        "    ax.plot(ks, vals, \"o-\", color=color, lw=2, ms=8)\n",
        "    ax.axvline(3, color=\"grey\", lw=1.2, linestyle=\"--\", alpha=0.7,\n",
        "               label=\"k=3 retenu\")\n",
        "    if note and title.startswith(\"ARI\"):\n",
        "        ax.axhline(0.60, color=\"#3C9E6E\", lw=1, linestyle=\":\", alpha=0.7,\n",
        "                   label=\"Seuil 0.60\")\n",
        "    if note and title.startswith(\"Silhouette\"):\n",
        "        ax.axhline(0.50, color=\"#3C9E6E\", lw=1, linestyle=\":\", alpha=0.7,\n",
        "                   label=\"Seuil 0.50\")\n",
        "    ax.set_xlabel(\"k\"); ax.set_xticks(ks)\n",
        "    ax.set_title(title, fontsize=9)\n",
        "    ax.legend(fontsize=7)\n",
        "\n",
        "    # Annoter k=3\n",
        "    idx3 = ks.index(3)\n",
        "    ax.annotate(f\"{vals[idx3]:.3f}\", xy=(3, vals[idx3]),\n",
        "                xytext=(3.3, vals[idx3]), fontsize=9, color=color,\n",
        "                arrowprops=dict(arrowstyle=\"->\", color=color, lw=0.8))\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/CRITIQUE_ARI_indices.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"✓ Figure — ARI + indices complets sauvegardée\")"
