    {
      "cell_type": "code",
      "source": [
        "# ANALYSE THERMO-COMPORTEMENTALE — ALGER — VERSION FINALE SIMPLIFIÉE\n",
        "# Compatible Google Colab — cellules indépendantes\n",
        "# Exigences Q1 : ACM → CAH (k=4) → LDA → Régression ordinale\n",
        "# =============================================================================\n",
        "\n",
        "\n",
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 1 — Installation                                              ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "!pip install pandas numpy scipy scikit-learn matplotlib seaborn statsmodels openpyxl -q"
      ],
      "metadata": {
        "id": "xR8ZZsH3FVKQ"
      },
      "execution_count": 2,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 2 — Imports + chargement + nettoyage                          ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.patches as mpatches\n",
        "import seaborn as sns\n",
        "from scipy.linalg import svd\n",
        "from scipy.cluster.hierarchy import linkage, fcluster, dendrogram\n",
        "from scipy.stats import (chi2_contingency, mannwhitneyu,\n",
        "                         kruskal, spearmanr)\n",
        "from scipy.stats import pointbiserialr\n",
        "from sklearn.cluster import KMeans\n",
        "from sklearn.discriminant_analysis import LinearDiscriminantAnalysis\n",
        "from sklearn.model_selection import StratifiedKFold, cross_val_score, cross_val_predict\n",
        "from sklearn.metrics import (silhouette_score, davies_bouldin_score,\n",
        "                              calinski_harabasz_score, adjusted_rand_score,\n",
        "                              classification_report, confusion_matrix)\n",
        "from statsmodels.miscmodels.ordinal_model import OrderedModel\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "# ── Palette ──────────────────────────────────────────────────────────────\n",
        "PAL = {0:\"#185FA5\", 1:\"#D85A30\", 2:\"#3C9E6E\", 3:\"#7B3FA0\"}\n",
        "plt.rcParams.update({\"figure.dpi\":120,\"font.size\":10,\n",
        "                     \"axes.spines.top\":False,\"axes.spines.right\":False,\n",
        "                     \"axes.grid\":True,\"grid.alpha\":0.25})\n",
        "\n",
        "# ── Chargement ────────────────────────────────────────────────────────────\n",
        "df_raw = pd.read_excel(\"/article_rymel.xlsx\", sheet_name=\"nouha_draft\")\n",
        "\n",
        "RENAME = {\n",
        "    \"Age\":\"age\",\"Area (m²)\":\"superficie\",\"Floor\":\"etage\",\n",
        "    \"Are you on the top floor ?\":\"dernier_etage\",\n",
        "    \"Facade orientation\":\"orientation\",\"Windows material\":\"mat_fenetres\",\n",
        "    \"Glass type\":\"vitrage_type\",\"Shutter state\":\"volet_etat\",\n",
        "    \"Roof waterproofing status\":\"toiture_etat\",\n",
        "    \"Does air get through closed windows?\":\"infiltr_air\",\n",
        "    \"Water infiltration\":\"infiltr_eau\",\"Moisture and mold\":\"humidite\",\n",
        "    \"Do you experience cold drafts frequently?\":\"courants_froids\",\n",
        "    \"How would you rate the temperature in the rooms facing the street (or the main facade)?\":\"sensation\",\n",
        "    \"Summer thermal satisfaction\":\"sat_ete\",\n",
        "    \"Winter thermal satisfaction\":\"sat_hiver\",\n",
        "    \"Rate thermal comfort\":\"score_confort\",\n",
        "    \"Turn on a fan/the AC\":\"beh_fan_ac\",\n",
        "    \"Close the shutters\":\"beh_volets_ete\",\n",
        "    \"Open the windows\":\"beh_fen_ouv\",\n",
        "    \" Put on lighter clothes\":\"beh_vets_legers\",\n",
        "    \"Turn on or turn up the heating\":\"beh_chauffage\",\n",
        "    \"Put on warmer clothes\":\"beh_vets_chauds\",\n",
        "    \"Close the windows\":\"beh_fen_ferm\",\n",
        "    \"Occupant status\":\"statut\",\n",
        "}\n",
        "df = df_raw.rename(columns={k:v for k,v in RENAME.items() if k in df_raw.columns})\n",
        "\n",
        "# ── Encodages ─────────────────────────────────────────────────────────────\n",
        "sat_map = {\"-2 dissatisfied\":-2,\"-1 Somewhat dissatisfied\":-1,\n",
        "           \"0 Acceptable\":0,\"+1 Somewhat satisfied\":1,\"+2 Satisfied\":2}\n",
        "for col in [\"sat_ete\",\"sat_hiver\"]:\n",
        "    df[col+\"_num\"] = df[col].map(sat_map)\n",
        "\n",
        "sens_map = {\"-2 Very cold\":-2,\"-2 Cold\":-2,\"-1 Slightly chilly\":-1,\n",
        "            \"-1 Cool\":-1,\"0 Neutral\":0,\"0 Comfortable\":0,\n",
        "            \"+1 Slightly hot\":1,\"+2 Hot\":2}\n",
        "df[\"sensation_num\"] = df[\"sensation\"].map(sens_map)\n",
        "\n",
        "for col in [\"infiltr_air\",\"infiltr_eau\",\"humidite\",\"courants_froids\"]:\n",
        "    df[col+\"_bin\"] = (df[col]==\"Yes\").astype(int)\n",
        "\n",
        "df[\"vitrage_simple_bin\"] = df[\"vitrage_type\"].apply(\n",
        "    lambda x: 0 if \"Double\" in str(x) and \"Single\" not in str(x) else 1)\n",
        "\n",
        "for col, m in [(\"volet_etat\",{\"Good\":2,\"Medium\":1,\"Degraded\":0}),\n",
        "               (\"toiture_etat\",{\"Good\":2,\"Medium\":1,\"Degraded\":0})]:\n",
        "    df[col+\"_num\"] = df[col].map(m)\n",
        "\n",
        "print(f\"✅ Données : {df.shape[0]} ménages × {df.shape[1]} variables\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "sX9gEVH-GHRP",
        "outputId": "7b9c5c0b-f3b1-477e-a850-d912ed820001"
      },
      "execution_count": 6,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Données : 125 ménages × 84 variables\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "f9904b95",
        "outputId": "6d758f3d-5cc3-4534-d160-040693277575"
      },
      "source": [
        "import os\n",
        "print(os.listdir('.'))"
      ],
      "execution_count": 5,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "['.config', 'sample_data']\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 3 — ACM                                                       ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "acm_raw = pd.DataFrame({\n",
        "    \"Sensation\"  : df[\"sensation\"],\n",
        "    \"Sat_Ete\"    : df[\"sat_ete\"],\n",
        "    \"Sat_Hiver\"  : df[\"sat_hiver\"],\n",
        "    \"Fan_AC\"     : df[\"beh_fan_ac\"].map({1:\"Fan_Oui\",0:\"Fan_Non\"}),\n",
        "    \"Volets_Ete\" : df[\"beh_volets_ete\"].map({1:\"Vol_Oui\",0:\"Vol_Non\"}),\n",
        "    \"Fen_Ouv\"    : df[\"beh_fen_ouv\"].map({1:\"FenO_Oui\",0:\"FenO_Non\"}),\n",
        "    \"Chauffage\"  : df[\"beh_chauffage\"].map({1:\"Chauf_Oui\",0:\"Chauf_Non\"}),\n",
        "    \"Vets_Chauds\": df[\"beh_vets_chauds\"].map({1:\"VW_Oui\",0:\"VW_Non\"}),\n",
        "    \"Fen_Ferm\"   : df[\"beh_fen_ferm\"].map({1:\"FenF_Oui\",0:\"FenF_Non\"}),\n",
        "    \"Infiltr_Air\": df[\"infiltr_air\"],\n",
        "    \"Infiltr_Eau\": df[\"infiltr_eau\"],\n",
        "    \"Humidite\"   : df[\"humidite\"],\n",
        "    \"Courants\"   : df[\"courants_froids\"],\n",
        "    \"Vitrage\"    : df[\"vitrage_type\"].apply(\n",
        "        lambda x: \"Double\" if \"Double\" in str(x) and \"Single\" not in str(x) else \"Simple\"),\n",
        "    \"Volet_Etat\" : df[\"volet_etat\"],\n",
        "    \"Toiture\"    : df[\"toiture_etat\"],\n",
        "}, index=df.index).dropna()\n",
        "\n",
        "N_acm, Q = acm_raw.shape\n",
        "Z         = pd.get_dummies(acm_raw, drop_first=False).astype(float)\n",
        "K         = Z.shape[1]\n",
        "Z_arr     = Z.values\n",
        "n_tot     = Z_arr.sum()\n",
        "r_m       = Z_arr.sum(axis=1)\n",
        "c_m       = Z_arr.sum(axis=0)\n",
        "P         = Z_arr / n_tot\n",
        "rc        = np.outer(r_m/n_tot, c_m/n_tot)\n",
        "S         = (P - rc) / (np.sqrt(np.outer(r_m/n_tot, c_m/n_tot)) + 1e-12)\n",
        "U, sigma, Vt = svd(S, full_matrices=False)\n",
        "eig       = sigma**2\n",
        "inertia_T = (K - Q) / Q\n",
        "exp_pct   = eig / inertia_T * 100\n",
        "cum_pct   = np.cumsum(exp_pct)\n",
        "F_acm     = U[:,:8] * sigma[:8]     # coordonnées individus\n",
        "G_acm     = Vt[:8,:].T * sigma[:8]  # coordonnées modalités\n",
        "mod_names = Z.columns.tolist()\n",
        "X_clust   = F_acm[:,:5]             # 5 dims pour clustering\n",
        "\n",
        "print(f\"✅ ACM : N={N_acm}, Q={Q}, K={K}\")\n",
        "print(f\"   Dim1={exp_pct[0]:.1f}%  Dim2={exp_pct[1]:.1f}%  Cum(1+2)={cum_pct[1]:.1f}%\")\n",
        "\n",
        "# ── Figure 1 : Scree plot ─────────────────────────────────────────────────\n",
        "fig, ax = plt.subplots(figsize=(9, 4))\n",
        "ax2 = ax.twinx()\n",
        "ax.bar(range(1,11), exp_pct[:10], color=\"#534AB7\", edgecolor=\"white\", alpha=0.85)\n",
        "ax2.plot(range(1,11), cum_pct[:10], \"o-\", color=\"#D85A30\", lw=2, ms=6)\n",
        "ax2.axhline(60, color=\"grey\", lw=0.8, linestyle=\"--\", alpha=0.6)\n",
        "ax.set_xlabel(\"Dimension ACM\")\n",
        "ax.set_ylabel(\"Inertie expliquée (%)\")\n",
        "ax2.set_ylabel(\"Inertie cumulée (%)\")\n",
        "ax.set_title(\"Figure 1 — Scree plot ACM\", fontweight=\"bold\")\n",
        "ax.set_xticks(range(1,11))\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/fig1_scree.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"✓ Figure 1 — Scree plot\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 291
        },
        "id": "YW_TNviDGyR9",
        "outputId": "34954f71-1535-4be2-ac89-6d6ede33edc8"
      },
      "execution_count": 8,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ ACM : N=116, Q=16, K=43\n",
            "   Dim1=10.6%  Dim2=9.0%  Cum(1+2)=19.6%\n"
          ]
        },
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1080x480 with 2 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✓ Figure 1 — Scree plot\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# ╔══════════════════════════════════════════════════════════════════════════╗\n",
        "# ║  CELLULE 4 — Choix du nombre de clusters (k=2 à 6)                    ║\n",
        "# ╚══════════════════════════════════════════════════════════════════════════╝\n",
        "\"\"\"\n",
        "RÉSULTATS PRÉ-CALCULÉS SUR CES DONNÉES :\n",
        "k=2 : Silhouette=0.278, DB=1.237, CH=23.75, ARI=0.739  Distribution: 14/102\n",
        "k=3 : Silhouette=0.272, DB=1.353, CH=24.90, ARI=0.236  Distribution: 14/14/88\n",
        "k=4 : Silhouette=0.220, DB=1.331, CH=27.95, ARI=0.501  Distribution: 14/14/24/64\n",
        "k=5 : Silhouette=0.259, DB=1.181, CH=33.27, ARI=0.625  Distribution: 14/14/24/20/44\n",
        "\n",
        "DÉCISION : k=4 retenu car :\n",
        "  - Calinski-Harabasz le plus élevé parmi k=2..4\n",
        "  - ARI(CAH/KM)=0.50 : concordance modérée mais meilleure que k=3 (0.24)\n",
        "  - C2(n=24) isolé : profil inconfort sévère (confort=5.12, sat.hiver=-1.83)\n",
        "    absent dans k=3 (noyé dans le grand cluster)\n",
        "  - Justification théorique : 4 profils cohérents avec la littérature POE\n",
        "\"\"\"\n",
        "\n",
        "Z_link = linkage(X_clust, method=\"ward\")\n",
        "ks     = list(range(2, 7))\n",
        "sils, dbs, chs, aris = [], [], [], []\n",
        "\n",
        "for k in ks:\n",
        "    cah_k = fcluster(Z_link, t=k, criterion=\"maxclust\") - 1\n",
        "    km_k  = KMeans(n_clusters=k, random_state=42, n_init=20).fit_predict(X_clust)\n",
        "    sils.append(silhouette_score(X_clust, cah_k))\n",
        "    dbs.append(davies_bouldin_score(X_clust, cah_k))\n",
        "    chs.append(calinski_harabasz_score(X_clust, cah_k))\n",
        "    aris.append(adjusted_rand_score(cah_k, km_k))\n",
        "\n",
        "print(\"Tableau des indices de validation :\")\n",
        "print(f\"{'k':>3} | {'Silhouette↑':>12} | {'Davies-B↓':>10} | {'Calinski↑':>10} | {'ARI↑':>8}\")\n",
        "print(\"─\"*52)\n",
        "for i, k in enumerate(ks):\n",
        "    flag = \" ← retenu\" if k==4 else \"\"\n",
        "    print(f\"{k:>3} | {sils[i]:>12.4f} | {dbs[i]:>10.4f} | {chs[i]:>10.2f} | {aris[i]:>8.4f}{flag}\")\n",
        "\n",
        "# ── Figure 2 : indices de validation ─────────────────────────────────────\n",
        "fig, axes = plt.subplots(2, 2, figsize=(12, 8))\n",
        "fig.suptitle(\"Figure 2 — Indices de validation des clusters (CAH Ward)\",\n",
        "             fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "for ax, vals, title, col, note in [\n",
        "    (axes[0,0], sils, \"Silhouette (↑ meilleur)\",       \"#185FA5\", \"\"),\n",
        "    (axes[0,1], dbs,  \"Davies-Bouldin (↓ meilleur)\",   \"#D85A30\", \"\"),\n",
        "    (axes[1,0], chs,  \"Calinski-Harabasz (↑ meilleur)\",\"#3C9E6E\", \"\"),\n",
        "    (axes[1,1], aris, \"ARI — Concordance CAH/K-Means\\n(↑ = plus robuste)\", \"#7B3FA0\", \"\"),\n",
        "]:\n",
        "    ax.plot(ks, vals, \"o-\", color=col, lw=2, ms=8)\n",
        "    ax.axvline(4, color=\"grey\", lw=1.5, linestyle=\"--\", label=\"k=4 retenu\")\n",
        "    ax.set_xlabel(\"Nombre de clusters k\")\n",
        "    ax.set_xticks(ks)\n",
        "    ax.set_title(title, fontsize=9)\n",
        "    ax.legend(fontsize=8)\n",
        "    # Annoter k=4\n",
        "    idx4 = ks.index(4)\n",
        "    ax.annotate(f\"{vals[idx4]:.3f}\", xy=(4, vals[idx4]),\n",
        "                xytext=(4.3, vals[idx4]), fontsize=9, color=col)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/fig2_validation_indices.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "print(\"✓ Figure 2 — Indices de validation\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 509
        },
        "id": "WIbczFMKHTPx",
        "outputId": "1fb3b708-6322-4388-fb14-993c1dc76754"
      },
      "execution_count": 10,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Tableau des indices de validation :\n",
            "  k |  Silhouette↑ |  Davies-B↓ |  Calinski↑ |     ARI↑\n",
            "────────────────────────────────────────────────────\n",
            "  2 |       0.2777 |     1.2374 |      23.75 |   0.7387\n",
            "  3 |       0.2715 |     1.3525 |      24.90 |   0.2357\n",
            "  4 |       0.2198 |     1.3307 |      27.95 |   0.5005 ← retenu\n",
            "  5 |       0.2592 |     1.1805 |      33.27 |   0.6253\n",
            "  6 |       0.2483 |     1.1577 |      32.09 |   0.6322\n"
          ]
        },
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1440x960 with 4 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        },
        {
          "output_type": "stream",
