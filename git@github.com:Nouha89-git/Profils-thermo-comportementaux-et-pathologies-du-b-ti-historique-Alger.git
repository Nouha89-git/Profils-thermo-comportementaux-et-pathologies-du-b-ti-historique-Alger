    {
      "cell_type": "code",
      "source": [
        "# K-Means sur les 5 premières dimensions ACM\n",
        "km3 = KMeans(n_clusters=3, random_state=42, n_init=20)\n",
        "km_labels = km3.fit_predict(X_clust)\n",
        "\n",
        "km_names = {0:\"KM0\", 1:\"KM1\", 2:\"KM2\"}\n",
        "PAL_KM   = {0:\"#185FA5\", 1:\"#D85A30\", 2:\"#3C9E6E\"}\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
        "fig.suptitle(\"Carte individuelle ACM — CAH Ward vs K-Means (k=3)\",\n",
        "             fontsize=12, fontweight=\"bold\")\n",
        "\n",
        "# Plan Dim1 × Dim2\n",
        "for ax, labels_used, title, pal in [\n",
        "    (axes[0], cah_lab,   \"CAH Ward\", {0:\"#185FA5\",1:\"#D85A30\",2:\"#3C9E6E\"}),\n",
        "    (axes[1], km_labels, \"K-Means\",  PAL_KM),\n",
        "]:\n",
        "    ax.axhline(0, color=\"grey\", lw=0.4, alpha=0.5)\n",
        "    ax.axvline(0, color=\"grey\", lw=0.4, alpha=0.5)\n",
        "    for cl, col in pal.items():\n",
        "        mask = labels_used == cl\n",
        "        ax.scatter(F[mask,0], F[mask,1], color=col, s=55, alpha=0.75,\n",
        "                   edgecolors=\"white\", lw=0.4, label=f\"Cluster {cl} (n={mask.sum()})\")\n",
        "        # Centroïde\n",
        "        ax.scatter(F[mask,0].mean(), F[mask,1].mean(),\n",
        "                   color=col, marker=\"*\", s=300, zorder=6,\n",
        "                   edgecolors=\"black\", lw=0.6)\n",
        "    ax.set_xlabel(f\"Dim 1 — {exp_pct[0]:.1f}%\")\n",
        "    ax.set_ylabel(f\"Dim 2 — {exp_pct[1]:.1f}%\")\n",
        "    ax.set_title(title)\n",
        "    ax.legend(fontsize=8)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"/content/C_individual_map_clusters.png\", bbox_inches=\"tight\", dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# Comparaison CAH vs K-Means\n",
        "print(\"\\nComparaison CAH vs K-Means :\")\n",
        "print(pd.crosstab(cah_lab, km_labels,\n",
        "                  rownames=[\"CAH\"], colnames=[\"K-Means\"]))\n",
        "sil_km = silhouette_score(X_clust, km_labels)\n",
        "sil_ca = silhouette_score(X_clust, cah_lab)\n",
        "print(f\"\\nSilhouette CAH    = {sil_ca:.4f}\")\n",
        "print(f\"Silhouette K-Means = {sil_km:.4f}\")\n",
        "print(\"✓ Figure C — Individual map clusters\")"
      ],
