        "\n",
        "print(f\"\"\"\n",
        "SECTION 4 — TESTS STATISTIQUES\n",
        "────────────────────────────────\n",
        "Kruskal-Wallis (confort)    : H={H:.3f}, p={p_kruskal:.4f} ***\n",
