        "            va=\"center\", ha=\"left\" if val>=0 else \"right\", fontsize=8)\n",
        "ax.set_xlabel(\"Spearman r\")\n",
        "ax.set_title(\"Figure 12 — Spearman Correlations with Thermal Comfort Score\\n\"\n",
        "             \"(FDR-corrected; green=positive, red=negative)\", fontweight=\"bold\")\n",
        "ax.set_xlim(-0.8, 0.8)\n",
        "save(\"fig12_spearman_correlations\")"
